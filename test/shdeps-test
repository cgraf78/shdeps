#!/usr/bin/env bash
# shellcheck disable=SC2154,SC2034
# SC2154: variables set by sourced shdeps.sh (_name, _method, _SHDEPS_DEPS, etc.)
# SC2034: variables read by sourced shdeps.sh (SHDEPS_CONF, SHDEPS_FORCE, etc.)
#
# shdeps-test — comprehensive test suite for shdeps.sh
#
# Usage: ./test/shdeps-test
#
# Tests are organized by section matching the library's architecture.
# Each section uses echo "=== Section Name ===" headers.
# All tests run in an isolated mock HOME to avoid touching real system.

set -uo pipefail

SHDEPS_DIR="$(cd "$(dirname "$0")/.." && pwd)"

# shellcheck source=helpers.sh
. "$(dirname "$0")/helpers.sh"

# Set up isolated environment
_mock_home
_source_shdeps "$SHDEPS_DIR"

# ===========================================================================
# Section 1: Config parsing
# ===========================================================================

echo "=== Config parsing ==="

# --- Well-formed deps.conf ---

_test_conf_dir=$(_tmpdir)
cat >"$_test_conf_dir/deps.conf" <<'EOF'
jq        pkg
bat       pkg       bat    batcat
fd        pkg       fd     fdfind     apt:fd-find,dnf:fd-find
ds        git       -      -          -                cgraf78/ds.git   .local/share/ds
neovim    binary    nvim   -          -                neovim/neovim
nerd-fonts custom
EOF

SHDEPS_CONF="$_test_conf_dir/deps.conf"
_shdeps_load
_assert_eq "well-formed: entry count" "6" "${#_SHDEPS_DEPS[@]}"
_assert_contains "well-formed: first entry is jq" "jq" "${_SHDEPS_DEPS[0]}"
_assert_contains "well-formed: last entry is nerd-fonts" "nerd-fonts" "${_SHDEPS_DEPS[5]}"

# --- Minimal entry (name + method only) ---

cat >"$_test_conf_dir/deps.conf" <<'EOF'
jq  pkg
EOF
_shdeps_load
_assert_eq "minimal entry: count" "1" "${#_SHDEPS_DEPS[@]}"
_assert_eq "minimal entry: content" "jq|pkg" "${_SHDEPS_DEPS[0]}"

# --- Maximal entry (all 9 fields) ---

cat >"$_test_conf_dir/deps.conf" <<'EOF'
fd  pkg  fd  fdfind  apt:fd-find,dnf:fd-find  -  -  linux,darwin  nas
EOF
_shdeps_load
_assert_eq "maximal entry: count" "1" "${#_SHDEPS_DEPS[@]}"
_assert_contains "maximal entry: has platforms" "linux,darwin" "${_SHDEPS_DEPS[0]}"
_assert_contains "maximal entry: has hosts" "nas" "${_SHDEPS_DEPS[0]}"

# --- Comments and blank lines ---

cat >"$_test_conf_dir/deps.conf" <<'EOF'
# This is a comment
   # Indented comment

tool-a  pkg


tool-b  pkg
EOF
_shdeps_load
_assert_eq "comments/blanks: count" "2" "${#_SHDEPS_DEPS[@]}"
_assert_contains "comments/blanks: first" "tool-a" "${_SHDEPS_DEPS[0]}"
_assert_contains "comments/blanks: second" "tool-b" "${_SHDEPS_DEPS[1]}"

# --- Missing config file ---

SHDEPS_CONF="$_test_conf_dir/nonexistent.conf"
unset SHDEPS_CONF_LOCAL
_shdeps_load
_assert_eq "missing conf: empty deps" "0" "${#_SHDEPS_DEPS[@]}"

# --- Local config overlay ---

cat >"$_test_conf_dir/deps.conf" <<'EOF'
tool-a  pkg
tool-b  pkg
EOF
cat >"$_test_conf_dir/deps.local.conf" <<'EOF'
tool-c  binary  -  -  -  owner/tool-c
EOF
SHDEPS_CONF="$_test_conf_dir/deps.conf"
unset SHDEPS_CONF_LOCAL
_shdeps_load
_assert_eq "conf + local: entry count" "3" "${#_SHDEPS_DEPS[@]}"
_assert_contains "conf + local: has local entry" "tool-c" "${_SHDEPS_DEPS[2]}"

# --- Local config only (no main conf) ---

rm -f "$_test_conf_dir/deps.conf"
_shdeps_load
_assert_eq "local only: entry count" "1" "${#_SHDEPS_DEPS[@]}"
_assert_contains "local only: has entry" "tool-c" "${_SHDEPS_DEPS[0]}"

# --- Neither file → empty deps ---

rm -f "$_test_conf_dir/deps.local.conf"
_shdeps_load
_assert_eq "neither: empty deps" "0" "${#_SHDEPS_DEPS[@]}"

# --- Public shdeps_load returns count ---

cat >"$_test_conf_dir/deps.conf" <<'EOF'
a  pkg
b  pkg
c  pkg
EOF
SHDEPS_CONF="$_test_conf_dir/deps.conf"
count=$(shdeps_load)
_assert_eq "shdeps_load: returns count" "3" "$count"

# --- Dash fields preserved as literal in raw entry ---

cat >"$_test_conf_dir/deps.conf" <<'EOF'
ds  git  -  -  -  cgraf78/ds.git  .local/share/ds
EOF
_shdeps_load
_assert_contains "dash fields: preserved in entry" "ds|git|-|-|-|cgraf78/ds.git|.local/share/ds" "${_SHDEPS_DEPS[0]}"

# ===========================================================================
# Section 2: Entry parsing
# ===========================================================================

echo ""
echo "=== Entry parsing ==="

# --- Full entry with all fields ---

_shdeps_parse "fd|pkg|fd|fdfind|apt:fd-find,dnf:fd-find|owner/fd|.local/share/fd|linux,darwin"
_assert_eq "parse full: name" "fd" "$_name"
_assert_eq "parse full: method" "pkg" "$_method"
_assert_eq "parse full: cmd" "fd" "$_cmd"
_assert_eq "parse full: cmd_alt" "fdfind" "$_cmd_alt"
_assert_eq "parse full: pkg_overrides" "apt:fd-find,dnf:fd-find" "$_pkg_overrides"
_assert_eq "parse full: repo" "owner/fd" "$_repo"
_assert_eq "parse full: dir" ".local/share/fd" "$_dir"
_assert_eq "parse full: platforms" "linux,darwin" "$_platforms"
_assert_eq "parse full: hosts empty when absent" "" "$_hosts"

# --- Dash fields normalize to empty ---

_shdeps_parse "ds|git|-|-|-|cgraf78/ds.git|.local/share/ds|-"
_assert_eq "dash normalize: cmd defaults to name" "ds" "$_cmd"
_assert_eq "dash normalize: cmd_alt empty" "" "$_cmd_alt"
_assert_eq "dash normalize: pkg_overrides empty" "" "$_pkg_overrides"
_assert_eq "dash normalize: platforms empty" "" "$_platforms"
_assert_eq "dash normalize: hosts empty" "" "$_hosts"

# --- Minimal entry (name + method) ---

_shdeps_parse "jq|pkg"
_assert_eq "parse minimal: name" "jq" "$_name"
_assert_eq "parse minimal: method" "pkg" "$_method"
_assert_eq "parse minimal: cmd defaults to name" "jq" "$_cmd"
_assert_eq "parse minimal: cmd_alt empty" "" "$_cmd_alt"
_assert_eq "parse minimal: repo empty" "" "$_repo"

# --- cmd set explicitly ---

_shdeps_parse "neovim|binary|nvim"
_assert_eq "parse explicit cmd: name" "neovim" "$_name"
_assert_eq "parse explicit cmd: cmd" "nvim" "$_cmd"

# --- cmd_alt set ---

_shdeps_parse "bat|pkg|bat|batcat"
_assert_eq "parse cmd_alt: cmd" "bat" "$_cmd"
_assert_eq "parse cmd_alt: cmd_alt" "batcat" "$_cmd_alt"

# ===========================================================================
# Section 3: Platform matching
# ===========================================================================

echo ""
echo "=== Platform matching ==="

# Detect current platform for assertions
_current_os=$(uname -s | tr '[:upper:]' '[:lower:]')

# --- Empty spec matches all ---

_shdeps_platform_match ""
_assert_exit "empty spec: matches" 0 $?

# --- Include list: current platform ---

_shdeps_platform_match "$_current_os"
_assert_exit "include: current os matches" 0 $?

# --- Include list: other platform ---

if [[ "$_current_os" == "linux" ]]; then
  rc=0; _shdeps_platform_match "darwin" || rc=$?
  _assert_exit "include: other os rejected" 1 "$rc"
else
  rc=0; _shdeps_platform_match "linux" || rc=$?
  _assert_exit "include: other os rejected" 1 "$rc"
fi

# --- Include list: multiple platforms ---

_shdeps_platform_match "linux,darwin"
_assert_exit "include multi: linux,darwin matches" 0 $?

# --- Include list: none matching ---

rc=0; _shdeps_platform_match "freebsd,openbsd" || rc=$?
_assert_exit "include: no match rejected" 1 "$rc"

# --- Exclude list: excludes current ---

rc=0; _shdeps_platform_match "!${_current_os}" || rc=$?
_assert_exit "exclude: current os excluded" 1 "$rc"

# --- Exclude list: excludes other ---

if [[ "$_current_os" == "linux" ]]; then
  _shdeps_platform_match "!darwin"
  _assert_exit "exclude: other os not excluded" 0 $?
else
  _shdeps_platform_match "!linux"
  _assert_exit "exclude: other os not excluded" 0 $?
fi

# --- Exclude list: multiple excludes, none matching ---

if [[ "$_current_os" == "linux" ]]; then
  _shdeps_platform_match "!darwin,!freebsd"
  _assert_exit "exclude multi: none matching passes" 0 $?
else
  _shdeps_platform_match "!linux,!freebsd"
  _assert_exit "exclude multi: none matching passes" 0 $?
fi

# --- Mixed: exclude takes priority ---

rc=0; _shdeps_platform_match "${_current_os},!${_current_os}" || rc=$?
_assert_exit "mixed: exclude overrides include" 1 "$rc"

# --- Mixed: included and not excluded ---

if [[ "$_current_os" == "linux" ]]; then
  _shdeps_platform_match "linux,!darwin"
  _assert_exit "mixed: included and not excluded" 0 $?
else
  _shdeps_platform_match "darwin,!linux"
  _assert_exit "mixed: included and not excluded" 0 $?
fi

# --- Mixed: not in include list ---

if [[ "$_current_os" == "linux" ]]; then
  rc=0; _shdeps_platform_match "darwin,!freebsd" || rc=$?
  _assert_exit "mixed: not in include list" 1 "$rc"
else
  rc=0; _shdeps_platform_match "linux,!freebsd" || rc=$?
  _assert_exit "mixed: not in include list" 1 "$rc"
fi

# ===========================================================================
# Section 3b: Host matching
# ===========================================================================

echo ""
echo "=== Host matching ==="

# Detect current hostname for assertions
_current_host=$(hostname -s 2>/dev/null || hostname 2>/dev/null)
_current_host="${_current_host,,}"

# --- Empty spec matches all ---

_shdeps_host_match ""
_assert_exit "empty spec: matches" 0 $?

# --- Include list: current host ---

_shdeps_host_match "$_current_host"
_assert_exit "include: current host matches" 0 $?

# --- Include list: other host ---

rc=0; _shdeps_host_match "nonexistent-host-xyz" || rc=$?
_assert_exit "include: other host rejected" 1 "$rc"

# --- Include list: multiple hosts ---

_shdeps_host_match "other-host,$_current_host"
_assert_exit "include multi: current host in list matches" 0 $?

# --- Include list: none matching ---

rc=0; _shdeps_host_match "host-a,host-b" || rc=$?
_assert_exit "include: no match rejected" 1 "$rc"

# --- Exclude list: excludes current ---

rc=0; _shdeps_host_match "!${_current_host}" || rc=$?
_assert_exit "exclude: current host excluded" 1 "$rc"

# --- Exclude list: excludes other ---

_shdeps_host_match "!nonexistent-host-xyz"
_assert_exit "exclude: other host not excluded" 0 $?

# --- Exclude list: multiple excludes, none matching ---

_shdeps_host_match "!host-a,!host-b"
_assert_exit "exclude multi: none matching passes" 0 $?

# --- Mixed: exclude takes priority ---

rc=0; _shdeps_host_match "${_current_host},!${_current_host}" || rc=$?
_assert_exit "mixed: exclude overrides include" 1 "$rc"

# --- Mixed: included and not excluded ---

_shdeps_host_match "${_current_host},!other-host"
_assert_exit "mixed: included and not excluded" 0 $?

# --- Mixed: not in include list ---

rc=0; _shdeps_host_match "other-host,!nonexistent" || rc=$?
_assert_exit "mixed: not in include list" 1 "$rc"

# --- Case-insensitive matching ---

_upper_host="${_current_host^^}"
_shdeps_host_match "$_upper_host"
_assert_exit "case-insensitive: uppercase spec matches" 0 $?

rc=0; _shdeps_host_match "!${_upper_host}" || rc=$?
_assert_exit "case-insensitive: uppercase exclude works" 1 "$rc"

# ===========================================================================
# Section 3c: Entry parsing with hosts field
# ===========================================================================

echo ""
echo "=== Entry parsing (hosts field) ==="

# --- Full entry with all 9 fields ---

_shdeps_parse "codex|binary|codex|-|-|openai/codex|-|-|nas"
_assert_eq "parse hosts: name" "codex" "$_name"
_assert_eq "parse hosts: hosts" "nas" "$_hosts"

# --- Dash hosts normalize to empty ---

_shdeps_parse "jq|pkg|-|-|-|-|-|-|-"
_assert_eq "dash hosts: empty" "" "$_hosts"

# --- Missing hosts field → empty ---

_shdeps_parse "jq|pkg"
_assert_eq "missing hosts: empty" "" "$_hosts"

# --- Maximal entry with hosts ---

cat >"$_test_conf_dir/deps.conf" <<'EOF'
codex  binary  -  -  -  openai/codex  -  -  nas,taylor
EOF
SHDEPS_CONF="$_test_conf_dir/deps.conf"
_shdeps_load
_assert_contains "maximal with hosts: has hosts" "nas,taylor" "${_SHDEPS_DEPS[0]}"

# ===========================================================================
# Section 4: Package manager detection and resolution
# ===========================================================================

echo ""
echo "=== Package manager ==="

# --- _shdeps_pkg_detect with mock commands ---

_mock_bin_dir=$(_mock_bin)
export PATH="$_mock_bin_dir:$PATH"

# Mock brew on Darwin-like detection: _shdeps_pkg_detect checks uname first
# so we test the resolution and queuing logic directly instead.

# --- _shdeps_pkg_resolve: no overrides → returns name ---

_SHDEPS_PKG_MGR="apt"
result=$(_shdeps_pkg_resolve "fd" "")
_assert_eq "resolve: no overrides returns name" "fd" "$result"

# --- _shdeps_pkg_resolve: matching override ---

result=$(_shdeps_pkg_resolve "fd" "apt:fd-find,dnf:fd-find")
_assert_eq "resolve: apt override" "fd-find" "$result"

# --- _shdeps_pkg_resolve: non-matching override ---

_SHDEPS_PKG_MGR="pacman"
result=$(_shdeps_pkg_resolve "fd" "apt:fd-find,dnf:fd-find")
_assert_eq "resolve: no matching mgr returns name" "fd" "$result"

# --- _shdeps_pkg_resolve: NONE sentinel ---

_SHDEPS_PKG_MGR="apt"
result=$(_shdeps_pkg_resolve "nerd-fonts" "apt:NONE,brew:font-hack-nerd-font")
_assert_eq "resolve: NONE sentinel" "NONE" "$result"

# --- _shdeps_pkg_resolve: brew override ---

_SHDEPS_PKG_MGR="brew"
result=$(_shdeps_pkg_resolve "nerd-fonts" "apt:NONE,brew:font-hack-nerd-font")
_assert_eq "resolve: brew override" "font-hack-nerd-font" "$result"

# --- _shdeps_pkg_resolve: multiple overrides, first match wins ---

_SHDEPS_PKG_MGR="dnf"
result=$(_shdeps_pkg_resolve "bat" "apt:bat,dnf:bat-extra,pacman:bat")
_assert_eq "resolve: dnf gets its override" "bat-extra" "$result"

# --- _shdeps_pkg_queue: NONE skips silently ---

_SHDEPS_PKG_MGR="apt"
_SHDEPS_PKG_BATCH=()
_SHDEPS_PKG_BATCH_NAMES=()
_shdeps_pkg_queue "nerd-fonts" "apt:NONE"
_assert_eq "queue: NONE skips" "0" "${#_SHDEPS_PKG_BATCH[@]}"

# --- _shdeps_pkg_queue: resolved package added to batch ---

# Mock _shdeps_pkg_available to always succeed for testing
# shellcheck disable=SC2317  # invoked indirectly via _shdeps_pkg_queue
_shdeps_pkg_available() { return 0; }
_SHDEPS_PKG_BATCH=()
_SHDEPS_PKG_BATCH_NAMES=()
_shdeps_pkg_queue "fd" "apt:fd-find"
_assert_eq "queue: adds resolved pkg" "1" "${#_SHDEPS_PKG_BATCH[@]}"
_assert_eq "queue: resolved name" "fd-find" "${_SHDEPS_PKG_BATCH[0]}"
_assert_eq "queue: original name" "fd" "${_SHDEPS_PKG_BATCH_NAMES[0]}"

# --- _shdeps_pkg_queue: multiple packages batch ---

_shdeps_pkg_queue "jq" ""
_assert_eq "queue: batch grows" "2" "${#_SHDEPS_PKG_BATCH[@]}"
_assert_eq "queue: second pkg" "jq" "${_SHDEPS_PKG_BATCH[1]}"

# --- _shdeps_pkg_queue: unavailable package skipped ---

# shellcheck disable=SC2317  # invoked indirectly via _shdeps_pkg_queue
_shdeps_pkg_available() { return 1; }
_SHDEPS_PKG_BATCH=()
_SHDEPS_PKG_BATCH_NAMES=()
_shdeps_pkg_queue "nonexistent-tool" ""
_assert_eq "queue: unavailable skipped" "0" "${#_SHDEPS_PKG_BATCH[@]}"

# Restore real _shdeps_pkg_available
_source_shdeps "$SHDEPS_DIR"

# --- _shdeps_pkg_detect: detects real system manager ---
# Just verify it sets something (or empty on unusual systems)

_shdeps_pkg_detect
_assert_match "pkg_detect: sets a known value" "^(brew|apt|dnf|pacman)?$" "$_SHDEPS_PKG_MGR"

# ===========================================================================
# Section 5: Binary asset matching
# ===========================================================================

echo ""
echo "=== Binary asset matching ==="

# Platform detection for test assertions
_test_os=$(uname -s | tr '[:upper:]' '[:lower:]')
_test_arch=$(uname -m)
case "$_test_arch" in
  x86_64)  _test_arch_alt=amd64 ;;
  aarch64) _test_arch_alt=arm64 ;;
  arm64)   _test_arch_alt=aarch64 ;;
  *)       _test_arch_alt="$_test_arch" ;;
esac
_test_OS="$(uname -s)"

# --- Rust triple: tar.gz with OS and arch ---

_json=$(_fake_release_json \
  "tool-x86_64-unknown-linux-gnu.tar.gz" \
  "tool-aarch64-unknown-linux-gnu.tar.gz" \
  "tool-x86_64-apple-darwin.tar.gz" \
  "tool-aarch64-apple-darwin.tar.gz")
result=$(_shdeps_binary_find_asset "tool" "test/tool" "v1.0.0" "$_json")
_assert_contains "rust triple: matches platform" "${_test_os}" "$result"
if [[ "$result" == *"${_test_arch}"* || "$result" == *"${_test_arch_alt}"* ]]; then
  _pass "rust triple: matches arch"
else
  _fail "rust triple: matches arch (expected '${_test_arch}' or '${_test_arch_alt}' in '$result')"
fi

# --- Go convention: plain binary ---

_json=$(_fake_release_json \
  "tool-linux-amd64" \
  "tool-linux-arm64" \
  "tool-darwin-arm64" \
  "tool-darwin-amd64")
result=$(_shdeps_binary_find_asset "tool" "test/tool" "v1.0.0" "$_json")
_assert_contains "go plain binary: matches platform" "${_test_os}" "$result"

# --- Case-insensitive: Darwin/Linux capitalized ---

_json=$(_fake_release_json \
  "tool_1.0_Darwin_arm64.tar.gz" \
  "tool_1.0_Darwin_x86_64.tar.gz" \
  "tool_1.0_Linux_arm64.tar.gz" \
  "tool_1.0_Linux_x86_64.tar.gz")
result=$(_shdeps_binary_find_asset "tool" "test/tool" "v1.0.0" "$_json")
_assert_contains "case-insensitive: matches platform" "${_test_OS}" "$result"

# --- Skip metadata extensions ---

_json=$(_fake_release_json \
  "tool-${_test_os}-${_test_arch_alt}.tar.gz.sha256" \
  "tool-${_test_os}-${_test_arch_alt}.tar.gz.sig" \
  "tool-${_test_os}-${_test_arch_alt}.tar.gz.asc" \
  "tool-${_test_os}-${_test_arch_alt}.sigstore" \
  "tool-${_test_os}-${_test_arch_alt}.tar.gz.b3" \
  "tool-${_test_os}-${_test_arch_alt}.tar.gz")
result=$(_shdeps_binary_find_asset "tool" "test/tool" "v1.0.0" "$_json")
_assert_contains "skip metadata: finds tarball" "tool-${_test_os}-${_test_arch_alt}.tar.gz" "$result"
_assert_not_contains "skip metadata: no sha256" "sha256" "$result"

# --- Skip package extensions ---

_json=$(_fake_release_json \
  "tool_1.0_${_test_os}_${_test_arch_alt}.deb" \
  "tool_1.0_${_test_os}_${_test_arch_alt}.rpm" \
  "tool_1.0_${_test_os}_${_test_arch_alt}.apk" \
  "tool_1.0_${_test_os}_${_test_arch_alt}.flatpak" \
  "tool_1.0_${_test_os}_${_test_arch_alt}.tar.gz")
result=$(_shdeps_binary_find_asset "tool" "test/tool" "v1.0.0" "$_json")
_assert_contains "skip packages: finds tarball" "tool_1.0_${_test_os}_${_test_arch_alt}.tar.gz" "$result"

# --- Alternate OS pattern: macos / linux aliases ---

if [[ "$_test_os" == "darwin" ]]; then
  _json=$(_fake_release_json \
    "tool-macos-arm64.tar.gz" \
    "tool-macos-x86_64.tar.gz" \
    "tool-linux-x86_64.tar.gz")
  result=$(_shdeps_binary_find_asset "tool" "test/tool" "v1.0.0" "$_json")
  _assert_contains "macos alias: matches macos" "macos" "$result"
else
  _json=$(_fake_release_json \
    "tool-macos-arm64.tar.gz" \
    "tool-linux-x86_64.tar.gz" \
    "tool-linux-arm64.tar.gz")
  result=$(_shdeps_binary_find_asset "tool" "test/tool" "v1.0.0" "$_json")
  _assert_contains "linux: picks linux not macos" "linux" "$result"
fi

# --- Prefer plain binary over tarball ---

_json=$(_fake_release_json \
  "tool-${_test_os}-${_test_arch_alt}" \
  "tool-${_test_os}-${_test_arch_alt}.tar.gz")
result=$(_shdeps_binary_find_asset "tool" "test/tool" "v1.0.0" "$_json")
_assert_not_contains "prefer plain over tarball" ".tar.gz" "$result"

# --- .tar.xz support ---

_json=$(_fake_release_json \
  "tool-${_test_arch}-unknown-${_test_os}-gnu.tar.xz" \
  "tool-${_test_arch_alt}-unknown-${_test_os}-gnu.tar.xz")
result=$(_shdeps_binary_find_asset "tool" "test/tool" "v1.0.0" "$_json")
_assert_contains "tar.xz: matches platform" "${_test_os}" "$result"

# --- .tgz support ---

_json=$(_fake_release_json \
  "tool-${_test_os}-${_test_arch_alt}.tgz" \
  "tool-${_test_os}-${_test_arch}.tgz")
result=$(_shdeps_binary_find_asset "tool" "test/tool" "v1.0.0" "$_json")
_assert_contains "tgz: matches platform" "${_test_os}" "$result"

# --- No matching asset → empty ---

_json=$(_fake_release_json \
  "tool-windows-amd64.exe" \
  "tool-freebsd-amd64.tar.gz")
result=$(_shdeps_binary_find_asset "tool" "test/tool" "v1.0.0" "$_json")
_assert_eq "no match: empty result" "" "$result"

# --- Tarball over zip preference ---

_json=$(_fake_release_json \
  "tool-${_test_os}-${_test_arch_alt}.tar.gz" \
  "tool-${_test_os}-${_test_arch_alt}.zip")
result=$(_shdeps_binary_find_asset "tool" "test/tool" "v1.0.0" "$_json")
_assert_contains "asset match: tarball over zip" ".tar.gz" "$result"

# --- Zip fallback when no tarball ---

_json=$(_fake_release_json \
  "tool-${_test_os}-${_test_arch_alt}.zip" \
  "tool-${_test_os}-${_test_arch_alt}.sha256")
result=$(_shdeps_binary_find_asset "tool" "test/tool" "v1.0.0" "$_json")
_assert_contains "asset match: zip when no tarball" ".zip" "$result"

# --- .gz single file matches plain pass ---

_json=$(_fake_release_json \
  "tool-${_test_os}-${_test_arch_alt}.gz" \
  "tool-${_test_os}-${_test_arch_alt}.tar.gz")
result=$(_shdeps_binary_find_asset "tool" "test/tool" "v1.0.0" "$_json")
_assert_contains "asset match: .gz matches plain pass" "tool-${_test_os}-${_test_arch_alt}.gz" "$result"

# --- .bz2 single file ---

_json=$(_fake_release_json \
  "tool_1.0_${_test_os}_${_test_arch_alt}.bz2")
result=$(_shdeps_binary_find_asset "tool" "test/tool" "v1.0.0" "$_json")
_assert_contains "asset match: .bz2 single file" "tool_1.0_${_test_os}_${_test_arch_alt}.bz2" "$result"

# --- .zst single file ---

_json=$(_fake_release_json \
  "tool-${_test_arch}-unknown-${_test_os}.zst" \
