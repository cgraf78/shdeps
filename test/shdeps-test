SHDEPS_STATE_DIR="$_hook_state_dir"
SHDEPS_REINSTALL=0
_source_shdeps "$SHDEPS_DIR"
_shdeps_load

# --- post() called ONLY for changed deps ---

cat >"$_hook_test_dir/tool-a.sh" <<'HOOK'
post() { echo "post-a" >> "$HOOK_LOG"; }
HOOK
cat >"$_hook_test_dir/tool-b.sh" <<'HOOK'
exists() { return 0; }
post() { echo "post-b" >> "$HOOK_LOG"; }
HOOK

: > "$HOOK_LOG"
declare -gA _SHDEPS_CHANGED=([tool-a]=1)
_shdeps_run_post_hooks
post_output=$(cat "$HOOK_LOG")
_assert_contains "post hooks: changed dep ran" "post-a" "$post_output"
_assert_not_contains "post hooks: unchanged dep skipped" "post-b" "$post_output"

# --- No changed deps → no post hooks run ---

: > "$HOOK_LOG"
declare -gA _SHDEPS_CHANGED=()
_shdeps_run_post_hooks
post_output=$(cat "$HOOK_LOG")
_assert_eq "post hooks: none changed, nothing ran" "" "$post_output"

# --- Post hook function isolation: one hook's functions don't leak ---

cat >"$_hook_test_dir/tool-a.sh" <<'HOOK'
post() { echo "post-a" >> "$HOOK_LOG"; }
HOOK
cat >"$_hook_test_dir/tool-b.sh" <<'HOOK'
exists() { return 0; }
# No post() defined
HOOK

: > "$HOOK_LOG"
declare -gA _SHDEPS_CHANGED=([tool-a]=1 [tool-b]=1)
_shdeps_run_post_hooks
post_output=$(cat "$HOOK_LOG")
_assert_contains "isolation: tool-a post ran" "post-a" "$post_output"
_assert_not_contains "isolation: tool-b post not leaked" "post-b" "$post_output"

# --- Error in post hook doesn't crash ---

cat >"$_hook_test_dir/tool-a.sh" <<'HOOK'
post() { return 1; }
HOOK
cat >"$_hook_test_dir/tool-b.sh" <<'HOOK'
exists() { return 0; }
post() { echo "post-b-ok" >> "$HOOK_LOG"; }
HOOK

: > "$HOOK_LOG"
declare -gA _SHDEPS_CHANGED=([tool-a]=1 [tool-b]=1)
_shdeps_run_post_hooks
post_output=$(cat "$HOOK_LOG")
_assert_contains "error handling: tool-b runs after tool-a fails" "post-b-ok" "$post_output"

# --- Missing hook file is silently skipped ---

rm -f "$_hook_test_dir/tool-b.sh"
: > "$HOOK_LOG"
