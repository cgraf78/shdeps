echo ""
echo "=== Single-file decompression ==="

_test_decompress() {
  local desc="$1" ext="$2"
  local staging
  staging=$(_tmpdir)
  cp "$_true_bin" "$staging/mytool"
  local compressed="$staging/mytool.$ext"
  case "$ext" in
    gz)  gzip -c "$staging/mytool" > "$compressed" ;;
    bz2) bzip2 -c "$staging/mytool" > "$compressed" ;;
    zst) zstd -qf "$staging/mytool" -o "$compressed" ;;
  esac
  rm "$staging/mytool"
  local bin_path="$staging/output-bin"
  local rc=0
  case "$ext" in
    gz)
      gzip -dc "$compressed" > "$bin_path" 2>/dev/null || rc=1
      [[ $rc -eq 0 ]] && chmod u+x "$bin_path"
      ;;
    bz2)
      bzip2 -dc "$compressed" > "$bin_path" 2>/dev/null || rc=1
      [[ $rc -eq 0 ]] && chmod u+x "$bin_path"
      ;;
    zst)
      zstd -df "$compressed" -o "$bin_path" 2>/dev/null || rc=1
      [[ $rc -eq 0 ]] && chmod u+x "$bin_path"
      ;;
  esac
  _assert_exit "$desc" 0 "$rc"
  if [[ -x "$bin_path" ]]; then
    _pass "$desc: binary decompressed"
  else
    _fail "$desc: binary not at $bin_path"
  fi
}

