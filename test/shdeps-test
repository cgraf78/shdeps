result=$(_shdeps_get_version "$_empty_dir")
_assert_eq "get_version: empty dir" "" "$result"

# --- _shdeps_get_version: VERSION file takes precedence over git ---

_both_dir=$(_tmpdir)
git -C "$_both_dir" init -q
git -C "$_both_dir" commit --allow-empty -m "init" -q
git -C "$_both_dir" tag "v9.9.9"
echo "2.0.0" > "$_both_dir/VERSION"
result=$(_shdeps_get_version "$_both_dir")
_assert_eq "get_version: VERSION over git tag" "v2.0.0" "$result"

# --- _shdeps_link_bin: creates symlink in ~/.local/bin ---

_link_dir=$(_tmpdir)
mkdir -p "$_link_dir/bin"
echo "#!/bin/sh" > "$_link_dir/bin/mytool"
chmod +x "$_link_dir/bin/mytool"
_shdeps_link_bin "mytool" "$_link_dir"
_assert_symlink "link_bin: symlink created" "$HOME/.local/bin/mytool"
_link_target=$(readlink "$HOME/.local/bin/mytool")
_assert_eq "link_bin: points to correct path" "$_link_dir/bin/mytool" "$_link_target"

# --- _shdeps_link_bin: no bin/<name> → no symlink ---

_nobin_dir=$(_tmpdir)
rm -f "$HOME/.local/bin/nobin-tool"
_shdeps_link_bin "nobin-tool" "$_nobin_dir"
_assert_file_missing "link_bin: no bin dir, no symlink" "$HOME/.local/bin/nobin-tool"

# --- _shdeps_link_bin: non-executable bin/<name> → no symlink ---

_nonexec_dir=$(_tmpdir)
mkdir -p "$_nonexec_dir/bin"
echo "data" > "$_nonexec_dir/bin/noexec-tool"
rm -f "$HOME/.local/bin/noexec-tool"
_shdeps_link_bin "noexec-tool" "$_nonexec_dir"
_assert_file_missing "link_bin: non-exec, no symlink" "$HOME/.local/bin/noexec-tool"

# --- _shdeps_dep_version: extracts version from --version output ---

_ver_bin_dir=$(_tmpdir)
cat > "$_ver_bin_dir/fake-tool" <<'SCRIPT'
#!/bin/sh
echo "fake-tool version 3.14.159"
SCRIPT
chmod +x "$_ver_bin_dir/fake-tool"
result=$(_shdeps_dep_version "$_ver_bin_dir/fake-tool")
_assert_eq "dep_version: extracts version" "3.14.159" "$result"

# --- _shdeps_dep_version: empty cmd → failure ---

rc=0; _shdeps_dep_version "" || rc=$?
_assert_exit "dep_version: empty cmd fails" 1 "$rc"

# --- _shdeps_exists: finds command in PATH ---

_exists_bin=$(_mock_bin)
echo '#!/bin/sh' > "$_exists_bin/test-exists-cmd"
chmod +x "$_exists_bin/test-exists-cmd"
export PATH="$_exists_bin:$PATH"
_shdeps_exists "test-exists-cmd" "" ""
_assert_exit "exists: finds cmd in PATH" 0 $?

# --- _shdeps_exists: tries cmd_alt ---

_shdeps_exists "nonexistent-primary" "test-exists-cmd" ""
_assert_exit "exists: falls back to cmd_alt" 0 $?

# --- _shdeps_exists: both missing → failure ---

rc=0; _shdeps_exists "no-such-cmd-aaa" "no-such-cmd-bbb" "" || rc=$?
_assert_exit "exists: both missing fails" 1 "$rc"

# --- Local clone detection: ~/git/<name> is preferred ---

_lc_test_dir=$(_tmpdir)
_lc_name="shdeps-lc-test"
_lc_clone="$HOME/git/$_lc_name"
_lc_install="$HOME/.local/share/$_lc_name"
_lc_state=$(_tmpdir)
SHDEPS_STATE_DIR="$_lc_state"
_source_shdeps "$SHDEPS_DIR"

# Create a fake local clone with a git repo
mkdir -p "$_lc_clone"
git -C "$_lc_clone" init -q
git -C "$_lc_clone" commit --allow-empty -m "init" -q

declare -gA _SHDEPS_CHANGED=()
_shdeps_install_from_github "$_lc_name" "owner/$_lc_name" "$_lc_install"

# Should create a symlink to local clone
_assert_symlink "local clone: install dir is symlink" "$_lc_install"
_lc_target=$(readlink "$_lc_install")
_assert_eq "local clone: points to ~/git/<name>" "$_lc_clone" "$_lc_target"
_assert_eq "local clone: marked as changed" "1" "${_SHDEPS_CHANGED[$_lc_name]:-0}"

# Cleanup
rm -rf "$_lc_clone" "$_lc_install"

# ===========================================================================
# Section 10: Integration / end-to-end
# ===========================================================================

echo ""
echo "=== Integration ==="

# Full shdeps_update cycle with mock config.
# Uses only 'custom' and 'pkg' (with already-installed commands) methods
# to avoid network access. Verifies the full orchestration:
# config → parse → dispatch → hooks.

_integ_dir=$(_tmpdir)
_integ_state=$(_tmpdir)
_integ_hooks="$_integ_dir/hooks.d"
mkdir -p "$_integ_hooks"

cat > "$_integ_dir/deps.conf" <<'EOF'
custom-a  custom
custom-b  custom
EOF

# Hook for custom-a: always runs (custom deps run when hook is due)
cat > "$_integ_hooks/custom-a.sh" <<'HOOK'
post() { echo "custom-a-post" >> "$INTEG_LOG"; return 0; }
status() { echo "custom-a-status" >> "$INTEG_LOG"; }
HOOK
# Hook for custom-b: post + status
cat > "$_integ_hooks/custom-b.sh" <<'HOOK'
post() { echo "custom-b-post" >> "$INTEG_LOG"; return 0; }
status() { echo "custom-b-status" >> "$INTEG_LOG"; }
HOOK

SHDEPS_CONF="$_integ_dir/deps.conf"
unset SHDEPS_CONF_LOCAL
SHDEPS_HOOKS_DIR="$_integ_hooks"
SHDEPS_STATE_DIR="$_integ_state"
SHDEPS_FORCE=0
SHDEPS_LOG_LEVEL=0
_source_shdeps "$SHDEPS_DIR"

INTEG_LOG="$_integ_dir/integ.log"
export INTEG_LOG
: > "$INTEG_LOG"

shdeps_update
integ_output=$(cat "$INTEG_LOG")

# Status hooks ran for all deps
_assert_contains "integ: custom-a status ran" "custom-a-status" "$integ_output"
_assert_contains "integ: custom-b status ran" "custom-b-status" "$integ_output"

# Post hooks ran (custom deps with no prior stamp are hook-due)
_assert_contains "integ: custom-a post ran" "custom-a-post" "$integ_output"
_assert_contains "integ: custom-b post ran" "custom-b-post" "$integ_output"

# --- Second run: hooks already touched, so post should NOT re-run ---

: > "$INTEG_LOG"
shdeps_update
integ_output=$(cat "$INTEG_LOG")

# Status always runs
_assert_contains "integ2: status still runs" "custom-a-status" "$integ_output"

# Post should NOT run (hook stamp is fresh)
_assert_not_contains "integ2: post skipped (stamp fresh)" "custom-a-post" "$integ_output"
_assert_not_contains "integ2: post-b skipped (stamp fresh)" "custom-b-post" "$integ_output"

# --- Force mode: re-runs all post hooks ---

SHDEPS_FORCE=1
_source_shdeps "$SHDEPS_DIR"
: > "$INTEG_LOG"
shdeps_update
integ_output=$(cat "$INTEG_LOG")
_assert_contains "integ force: custom-a post re-ran" "custom-a-post" "$integ_output"
_assert_contains "integ force: custom-b post re-ran" "custom-b-post" "$integ_output"

# Reset force
SHDEPS_FORCE=0
_source_shdeps "$SHDEPS_DIR"

# --- Integration with pkg deps: already-installed commands skip install ---

# Create a fake command so _shdeps_exists finds it
_integ_bin=$(_mock_bin)
echo '#!/bin/sh' > "$_integ_bin/fake-installed"
chmod +x "$_integ_bin/fake-installed"
export PATH="$_integ_bin:$PATH"

cat > "$_integ_dir/deps.conf" <<'EOF'
fake-installed  pkg  fake-installed
custom-a        custom
EOF

: > "$INTEG_LOG"
shdeps_update
integ_output=$(cat "$INTEG_LOG")

# The pkg dep should show up as present (not queued for install)
# custom-a should still get its status hook
_assert_contains "integ pkg: custom-a status" "custom-a-status" "$integ_output"

# --- Integration with local config overlay ---

cat > "$_integ_dir/deps.conf" <<'EOF'
custom-a  custom
EOF
cat > "$_integ_dir/deps.local.conf" <<'EOF'
custom-b  custom
EOF

SHDEPS_FORCE=1
_source_shdeps "$SHDEPS_DIR"
: > "$INTEG_LOG"
shdeps_update
integ_output=$(cat "$INTEG_LOG")
_assert_contains "integ overlay: custom-a from conf" "custom-a-post" "$integ_output"
_assert_contains "integ overlay: custom-b from local" "custom-b-post" "$integ_output"

# Reset
SHDEPS_FORCE=0
_source_shdeps "$SHDEPS_DIR"

# --- Integration: platform-filtered deps skip install but force still runs hooks ---
# Force mode marks ALL deps as changed (including platform-filtered ones).
# The platform filter only prevents _shdeps_install_dep from running.

if [[ "$_current_os" == "linux" ]]; then
  _skip_plat="darwin"
else
  _skip_plat="linux"
fi

cat > "$_integ_dir/deps.conf" <<EOF
custom-a  custom  -  -  -  -  -  $_skip_plat
custom-b  custom
EOF
rm -f "$_integ_dir/deps.local.conf"

# Without force: wrong-platform dep's custom hook is not due (stamp exists
# from earlier run), so it won't be marked changed — post skipped.
SHDEPS_FORCE=0
_source_shdeps "$SHDEPS_DIR"
# Ensure custom-a has a fresh hook stamp so it's not "due"
_shdeps_hook_touch "custom-a"
: > "$INTEG_LOG"
shdeps_update
integ_output=$(cat "$INTEG_LOG")
_assert_not_contains "integ platform: no-force skips wrong platform post" "custom-a-post" "$integ_output"
_assert_contains "integ platform: right platform runs" "custom-b" "$integ_output"

# --- shdeps_version ---

ver=$(shdeps_version)
_assert_match "shdeps_version: format" "^shdeps [0-9]+\.[0-9]+\.[0-9]+" "$ver"

# ===========================================================================

_test_summary
