mkdir -p "$_bs_dev_dir/shdeps"
cp -R "$_bs_dir"/. "$_bs_dev_dir/shdeps/"

SHDEPS_GIT_DEV_DIR="$_bs_dev_dir" SHDEPS_DIR="/nonexistent" \
  SHDEPS_BIN="$_bs_bin/shdeps" \
  . "$_bs_dir/install.sh" --bootstrap
if declare -f shdeps_update &>/dev/null; then
  _pass "bootstrap dev dir: shdeps_update defined"
else
  _fail "bootstrap dev dir: shdeps_update defined"
fi

# --- Bootstrap fresh install fallback ---

unset -f shdeps_update 2>/dev/null
_bs_fresh_dir=$(_tmpdir)/shdeps-fresh-bs
_bs_fresh_bin=$(_tmpdir)/fresh-bin
_bs_fresh_repo="$SHDEPS_DIR"
mkdir -p "$_bs_fresh_bin"

# Use the original SHDEPS_DIR (a git repo) as SHDEPS_REPO so _install
# can clone without network access
SHDEPS_DIR="$_bs_fresh_dir" SHDEPS_BIN="$_bs_fresh_bin/shdeps" \
  SHDEPS_REPO="$_bs_fresh_repo" SHDEPS_GIT_DEV_DIR="/nonexistent" \
  . "$_bs_dir/install.sh" --bootstrap
if declare -f shdeps_update &>/dev/null; then
  _pass "bootstrap fresh: shdeps_update defined"
else
  _fail "bootstrap fresh: shdeps_update defined"
fi
_assert_file_exists "bootstrap fresh: shdeps.sh installed" "$_bs_fresh_dir/shdeps.sh"

# Re-source the test shdeps for subsequent tests
_source_shdeps "$SHDEPS_DIR"

# ===========================================================================
# Section 12: self-update command
# ===========================================================================

echo ""
echo "=== self-update command ==="

# Set up a clone to test self-update against
_su_origin=$(_tmpdir)
git clone --bare "$SHDEPS_DIR" "$_su_origin" >/dev/null 2>&1
_su_dir=$(_tmpdir)/shdeps-su
git clone "$_su_origin" "$_su_dir" >/dev/null 2>&1
git -C "$_su_dir" config user.email "test@test.com"
git -C "$_su_dir" config user.name "Test"

# _shdeps_self_update uses its own state dir internally:
# ${XDG_STATE_HOME:-$HOME/.local/state}/shdeps
# Tests must use this path for stamp assertions.
_su_state="$HOME/.local/state/shdeps"
mkdir -p "$_su_state"
_source_shdeps "$SHDEPS_DIR"

# --- Fresh stamp triggers pull ---

SHDEPS_FORCE=0
_shdeps_self_update "$_su_dir" 2>/dev/null
_assert_file_exists "self-update: stamp created" "$_su_state/shdeps.self-update.stamp"

# --- Fresh stamp skips pull (within TTL) ---

# Push a new commit to origin from a separate worktree so origin is ahead
_su_ttl_work=$(_tmpdir)
git clone "$_su_origin" "$_su_ttl_work" >/dev/null 2>&1
git -C "$_su_ttl_work" config user.email "test@test.com"
git -C "$_su_ttl_work" config user.name "Test"
git -C "$_su_ttl_work" commit --allow-empty -m "ttl-marker" -q
git -C "$_su_ttl_work" push -q 2>/dev/null

_su_head_before=$(git -C "$_su_dir" rev-parse HEAD)
SHDEPS_FORCE=0
_shdeps_self_update "$_su_dir" 2>/dev/null
_su_head_after=$(git -C "$_su_dir" rev-parse HEAD)
_assert_eq "self-update TTL: no pull within TTL" "$_su_head_before" "$_su_head_after"

# --- Stale stamp triggers pull ---

echo "1000000000" > "$_su_state/shdeps.self-update.stamp"
_su_head_before=$(git -C "$_su_dir" rev-parse HEAD)
SHDEPS_FORCE=0
_shdeps_self_update "$_su_dir" 2>/dev/null
_su_head_after=$(git -C "$_su_dir" rev-parse HEAD)
_assert_neq "self-update stale: pull happened" "$_su_head_before" "$_su_head_after"

# --- Force bypasses TTL ---

# Push a new commit to origin from a separate worktree
_su_work=$(_tmpdir)
git clone "$_su_origin" "$_su_work" >/dev/null 2>&1
git -C "$_su_work" config user.email "test@test.com"
git -C "$_su_work" config user.name "Test"
git -C "$_su_work" commit --allow-empty -m "force-test" -q
git -C "$_su_work" push -q 2>/dev/null

_su_head_before=$(git -C "$_su_dir" rev-parse HEAD)
SHDEPS_FORCE=1
_shdeps_self_update "$_su_dir" 2>/dev/null
_su_head_after=$(git -C "$_su_dir" rev-parse HEAD)
_assert_neq "self-update force: pulled new commit" "$_su_head_before" "$_su_head_after"

# Reset force
SHDEPS_FORCE=0
_source_shdeps "$SHDEPS_DIR"

# --- Dirty working tree skips pull ---

echo "dirty" >> "$_su_dir/shdeps.sh"
# Make stamp stale so TTL wouldn't block
echo "1000000000" > "$_su_state/shdeps.self-update.stamp"
_su_head_before=$(git -C "$_su_dir" rev-parse HEAD)
_shdeps_self_update "$_su_dir" 2>/dev/null
_su_head_after=$(git -C "$_su_dir" rev-parse HEAD)
_assert_eq "self-update dirty: no pull" "$_su_head_before" "$_su_head_after"
git -C "$_su_dir" checkout -- shdeps.sh

# --- Non-git dir returns error ---

_su_nongit=$(_tmpdir)
rc=0
_shdeps_self_update "$_su_nongit" 2>/dev/null || rc=$?
_assert_exit "self-update non-git: exits 1" 1 "$rc"

# --- Re-sourcing under stdout redirection preserves ANSI codes ---
# Self-update re-sources shdeps.sh after pulling. If the caller redirected
# stdout (e.g. install.sh --bootstrap does >/dev/null), the [[ -t 1 ]]
# check would fail and wipe ANSI codes. The guard must preserve them.

_source_shdeps "$SHDEPS_DIR"
# Simulate initial source with a terminal — set ANSI codes
_SHDEPS_C_RESET=$'\033[0m'
_SHDEPS_C_CLEARLN=$'\r\033[2K'
# Re-source under stdout redirection (simulates self-update path)
. "$SHDEPS_DIR/shdeps.sh" >/dev/null
_assert_eq "re-source: ANSI codes preserved under >/dev/null" $'\033[0m' "$_SHDEPS_C_RESET"
_assert_eq "re-source: CLEARLN preserved under >/dev/null" $'\r\033[2K' "$_SHDEPS_C_CLEARLN"

# ===========================================================================

_test_summary
