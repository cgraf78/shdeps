SHDEPS_CONF_DIR="$_cust_conf_dir"
SHDEPS_HOOKS_DIR="$_cust_hooks_dir"
SHDEPS_STATE_DIR="$_cust_state_dir"
SHDEPS_REINSTALL=0
_source_shdeps "$SHDEPS_DIR"

# --- exists() returns 0 → present, no install ---

cat >"$_cust_conf_dir/deps.conf" <<'EOF'
present-tool  custom
EOF
_shdeps_load

cat >"$_cust_hooks_dir/present-tool.sh" <<'HOOK'
exists() { return 0; }
version() { echo "1.2.3"; }
install() { echo "should-not-run" >> "$HOOK_LOG"; return 0; }
HOOK

: > "$HOOK_LOG"
declare -gA _SHDEPS_CHANGED=()
_shdeps_install_dep "${_SHDEPS_DEPS[0]}"
_assert_eq "exists=0: install not called" "" "$(cat "$HOOK_LOG")"
_assert_eq "exists=0: not marked changed" "" "${_SHDEPS_CHANGED[present-tool]:-}"

# --- exists() returns 1 → install called, marked "added" ---

cat >"$_cust_conf_dir/deps.conf" <<'EOF'
missing-tool  custom
EOF
_shdeps_load

cat >"$_cust_hooks_dir/missing-tool.sh" <<'HOOK'
exists() { return 1; }
version() { echo "2.0.0"; }
install() { echo "install-ran" >> "$HOOK_LOG"; return 0; }
HOOK

: > "$HOOK_LOG"
declare -gA _SHDEPS_CHANGED=()
_shdeps_install_dep "${_SHDEPS_DEPS[0]}"
_assert_contains "exists=1: install called" "install-ran" "$(cat "$HOOK_LOG")"
_assert_eq "exists=1: marked changed" "1" "${_SHDEPS_CHANGED[missing-tool]:-0}"

# --- exists() returns 0 + reinstall → install called, marked "reinstalled" ---

cat >"$_cust_conf_dir/deps.conf" <<'EOF'
reinstall-tool  custom
EOF
_shdeps_load

cat >"$_cust_hooks_dir/reinstall-tool.sh" <<'HOOK'
exists() { return 0; }
install() { echo "reinstall-ran" >> "$HOOK_LOG"; return 0; }
HOOK

SHDEPS_REINSTALL=1
_source_shdeps "$SHDEPS_DIR"
_shdeps_load
: > "$HOOK_LOG"
declare -gA _SHDEPS_CHANGED=()
_shdeps_install_dep "${_SHDEPS_DEPS[0]}"
_assert_contains "reinstall: install called" "reinstall-ran" "$(cat "$HOOK_LOG")"
_assert_eq "reinstall: marked changed" "1" "${_SHDEPS_CHANGED[reinstall-tool]:-0}"

SHDEPS_REINSTALL=0
_source_shdeps "$SHDEPS_DIR"

# --- Missing exists() → warning, skipped ---

cat >"$_cust_conf_dir/deps.conf" <<'EOF'
no-exists-tool  custom
EOF
_shdeps_load

cat >"$_cust_hooks_dir/no-exists-tool.sh" <<'HOOK'
install() { echo "should-not-run" >> "$HOOK_LOG"; return 0; }
HOOK

: > "$HOOK_LOG"
declare -gA _SHDEPS_CHANGED=()
_shdeps_install_dep "${_SHDEPS_DEPS[0]}" 2>/dev/null
_assert_eq "no exists: install not called" "" "$(cat "$HOOK_LOG")"

# --- version() included in output ---

cat >"$_cust_conf_dir/deps.conf" <<'EOF'
ver-tool  custom
EOF
_shdeps_load

cat >"$_cust_hooks_dir/ver-tool.sh" <<'HOOK'
