# ===========================================================================
# Section 8b: Custom dep lifecycle — exists/version/install
# ===========================================================================

echo ""
echo "=== Custom dep lifecycle ==="

_cust_conf_dir=$(_tmpdir)
_cust_hooks_dir=$(_tmpdir)
_cust_state_dir=$(_tmpdir)
