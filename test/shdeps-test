_ver_log=$(_tmpdir)/ver.log
_shdeps_install_dep "${_SHDEPS_DEPS[0]}" >"$_ver_log"
_ver_output=$(cat "$_ver_log")
_assert_contains "version: included in added output" "3.14" "$_ver_output"
_source_shdeps "$SHDEPS_DIR"

# --- post() receives name as $1 ---

cat >"$_cust_conf_dir/deps.conf" <<'EOF'
name-tool  custom
EOF
_shdeps_load

cat >"$_cust_hooks_dir/name-tool.sh" <<'HOOK'
