# ===========================================================================
# Section 6: Binary extraction
# ===========================================================================

echo ""
echo "=== Tarball binary extraction ==="

# Find a real compiled binary for file(1) detection in sole-executable fallback.
# /usr/bin/true is available on virtually all systems.
_true_bin=""
for _candidate in /usr/bin/true /bin/true; do
  if [[ -x "$_candidate" ]] && file "$_candidate" | grep -qiE 'ELF|Mach-O'; then
    _true_bin="$_candidate"
    break
  fi
done
if [[ -z "$_true_bin" ]]; then
  echo "SKIP: no compiled binary found for extraction tests" >&2
  # Still count as passes so the suite doesn't misleadingly fail
  for _i in $(seq 1 20); do _pass "extraction: skipped (no compiled binary)"; done
else

  # Helper: create a tarball, run _shdeps_github_release_install_tarball, check result.
  # $1=desc $2=cmd $3=expected exit  remaining: executable file paths
  _test_tarball() {
    local desc="$1" cmd="$2" expect_exit="$3"
    shift 3
    _test_tarball_with_extras "$desc" "$cmd" "$expect_exit" "" "$@"
  }

  # $1=desc $2=cmd $3=expected exit $4=comma-separated non-executable files
  # remaining: executable file paths
  _test_tarball_with_extras() {
    local desc="$1" cmd="$2" expect_exit="$3" extras="$4"
    shift 4
    local staging
    staging=$(_tmpdir)
    local f
    for f in "$@"; do
      mkdir -p "$staging/$(dirname "$f")"
      cp "$_true_bin" "$staging/$f"
    done
    if [[ -n "$extras" ]]; then
      local -a _extra_files
      IFS=',' read -ra _extra_files <<<"$extras"
      for f in "${_extra_files[@]}"; do
        mkdir -p "$staging/$(dirname "$f")"
        echo "placeholder" >"$staging/$f"
      done
    fi
    local tarball
    tarball=$(mktemp "${TMPDIR:-/tmp}/tmp.XXXXXXXXXX.tar.gz")
    tar czf "$tarball" -C "$staging" .
    local bin_path="$staging/output-bin"
    local log=""
    local rc=0
    _shdeps_github_release_install_tarball "test-pkg" "$cmd" "$tarball" "$bin_path" "$log" >/dev/null 2>&1 || rc=$?
    _assert_exit "$desc" "$expect_exit" "$rc"
    if [[ "$expect_exit" -eq 0 ]]; then
      if [[ -L "$bin_path" || -x "$bin_path" ]]; then
        _pass "$desc: binary installed"
      else
        _fail "$desc: binary not installed at $bin_path"
      fi
    fi
    rm -f "$tarball"
  }

  # Exact name match (fzf, lazygit, starship)
  _test_tarball "exact match: flat binary" "mytool" 0 \
    "mytool"

  # Exact match in subdirectory (bat, delta, neovim)
  _test_tarball_with_extras "exact match: in subdir" "mytool" 0 \
    "mytool-v1.0-linux/README.md" \
    "mytool-v1.0-linux/mytool"

  # Exact match in bin/ subdir
  _test_tarball_with_extras "exact match: in bin subdir" "mytool" 0 \
    "mytool-v1.0/LICENSE" \
    "mytool-v1.0/bin/mytool"

  # Dash prefix match
  _test_tarball "prefix match: dash separator" "mytool" 0 \
    "mytool-x86_64-unknown-linux-gnu"

  # Underscore prefix match
  _test_tarball "prefix match: underscore separator" "mytool" 0 \
    "mytool_linux_amd64"

  # Sole executable fallback
  _test_tarball "sole executable: unconventional name" "mytool" 0 \
    "completely-different-name"

  # No match: multiple executables with wrong names
  _test_tarball "no match: multiple wrong names" "mytool" 1 \
    "other-tool" \
    "another-tool"

  # Sole executable fallback ignores shell scripts
  _test_script_staging=$(_tmpdir)
  echo "#!/bin/sh" >"$_test_script_staging/setup.sh"
  chmod +x "$_test_script_staging/setup.sh"
  cp "$_true_bin" "$_test_script_staging/real-binary"
  _test_script_tar=$(mktemp "${TMPDIR:-/tmp}/tmp.XXXXXXXXXX.tar.gz")
  tar czf "$_test_script_tar" -C "$_test_script_staging" .
  _test_script_bin="$_test_script_staging/output-bin"
  _shdeps_github_release_install_tarball "test-pkg" "notfound" "$_test_script_tar" "$_test_script_bin" "" >/dev/null 2>&1 || true
  if [[ -L "$_test_script_bin" ]]; then
    _target=$(readlink "$_test_script_bin")
    _assert_contains "sole exe ignores scripts: picks binary" "real-binary" "$_target"
  else
    _fail "sole exe ignores scripts: no symlink created"
  fi
  rm -f "$_test_script_tar"

  # Exact match preferred over prefix match
  _test_exact_staging=$(_tmpdir)
  cp "$_true_bin" "$_test_exact_staging/mytool"
  cp "$_true_bin" "$_test_exact_staging/mytool-extra"
  _test_exact_tar=$(mktemp "${TMPDIR:-/tmp}/tmp.XXXXXXXXXX.tar.gz")
  tar czf "$_test_exact_tar" -C "$_test_exact_staging" .
  _test_exact_bin="$_test_exact_staging/output-bin"
  _shdeps_github_release_install_tarball "test-pkg" "mytool" "$_test_exact_tar" "$_test_exact_bin" "" >/dev/null 2>&1
  if [[ -L "$_test_exact_bin" ]]; then
    _target=$(readlink "$_test_exact_bin")
    if [[ "$_target" == *"/mytool" && "$_target" != *"-extra" ]]; then
      _pass "exact over prefix: symlinks to exact name"
    else
      _fail "exact over prefix: symlinks to exact name (got $_target)"
    fi
  else
    _fail "exact over prefix: no symlink created"
  fi
  rm -f "$_test_exact_tar"

  # --- Zip extraction ---

  echo ""
  echo "=== Zip archive extraction ==="

  _test_zip() {
    local desc="$1" cmd="$2" expect_exit="$3"
    shift 3
    local staging
    staging=$(_tmpdir)
    local f
    for f in "$@"; do
      mkdir -p "$staging/$(dirname "$f")"
      cp "$_true_bin" "$staging/$f"
    done
    local zipfile="$staging/test.zip"
    (cd "$staging" && zip -qr "$zipfile" . -x test.zip)
    local bin_path="$staging/output-bin"
    local rc=0
    _shdeps_github_release_install_zip "test-pkg" "$cmd" "$zipfile" "$bin_path" "" >/dev/null 2>&1 || rc=$?
    _assert_exit "$desc" "$expect_exit" "$rc"
    if [[ "$expect_exit" -eq 0 ]]; then
      if [[ -L "$bin_path" || -x "$bin_path" ]]; then
        _pass "$desc: binary installed"
      else
        _fail "$desc: binary not installed at $bin_path"
      fi
    fi
  }

  if command -v zip &>/dev/null && command -v unzip &>/dev/null; then
    _test_zip "zip: exact match flat" "mytool" 0 "mytool"
    _test_zip "zip: exact match in subdir" "mytool" 0 "mytool-v1.0/bin/mytool"
    _test_zip "zip: prefix match" "mytool" 0 "mytool-x86_64-unknown-linux-gnu"
    _test_zip "zip: sole executable fallback" "mytool" 0 "different-name"
  else
    _pass "zip: exact match flat: skipped (zip/unzip not installed)"
    _pass "zip: exact match flat: binary installed: skipped"
    _pass "zip: exact match in subdir: skipped"
    _pass "zip: exact match in subdir: binary installed: skipped"
    _pass "zip: prefix match: skipped"
    _pass "zip: prefix match: binary installed: skipped"
    _pass "zip: sole executable fallback: skipped"
    _pass "zip: sole executable fallback: binary installed: skipped"
  fi

  # --- Single-file decompression ---

  echo ""
  echo "=== Single-file decompression ==="

  _test_decompress() {
    local desc="$1" ext="$2"
    local staging
    staging=$(_tmpdir)
    cp "$_true_bin" "$staging/mytool"
    local compressed="$staging/mytool.$ext"
    case "$ext" in
      gz) gzip -c "$staging/mytool" >"$compressed" ;;
      bz2) bzip2 -c "$staging/mytool" >"$compressed" ;;
      zst) zstd -qf "$staging/mytool" -o "$compressed" ;;
    esac
    rm "$staging/mytool"
    local bin_path="$staging/output-bin"
    local rc=0
    case "$ext" in
      gz)
        gzip -dc "$compressed" >"$bin_path" 2>/dev/null || rc=1
        [[ $rc -eq 0 ]] && chmod u+x "$bin_path"
        ;;
      bz2)
        bzip2 -dc "$compressed" >"$bin_path" 2>/dev/null || rc=1
        [[ $rc -eq 0 ]] && chmod u+x "$bin_path"
        ;;
      zst)
        zstd -df "$compressed" -o "$bin_path" 2>/dev/null || rc=1
        [[ $rc -eq 0 ]] && chmod u+x "$bin_path"
        ;;
    esac
    _assert_exit "$desc" 0 "$rc"
    if [[ -x "$bin_path" ]]; then
      _pass "$desc: binary decompressed"
    else
      _fail "$desc: binary not at $bin_path"
    fi
  }

  _test_decompress "gz decompression" "gz"
  _test_decompress "bz2 decompression" "bz2"
  if command -v zstd &>/dev/null; then
    _test_decompress "zst decompression" "zst"
  else
    _pass "zst decompression: skipped (zstd not installed)"
    _pass "zst decompression: binary decompressed: skipped"
  fi

fi # end of _true_bin guard

