#!/usr/bin/env bash
# shellcheck disable=SC1091,SC2154,SC2034
# SC1091: sourced files not passed as shellcheck input (resolved via -x flag)
# SC2154: variables set by sourced shdeps.sh (_name, _method, _SHDEPS_DEPS, etc.)
# SC2034: variables read by sourced shdeps.sh (SHDEPS_CONF_DIR, SHDEPS_FORCE, etc.)
#
# shdeps-test — comprehensive test suite for shdeps.sh
#
# Usage: ./test/shdeps-test
#
# Tests are organized by section matching the library's architecture.
# Each section uses echo "=== Section Name ===" headers.
# All tests run in an isolated mock HOME to avoid touching real system.

set -uo pipefail

SHDEPS_DIR="$(cd "$(dirname "$0")/.." && pwd)"

# shellcheck source=helpers.sh
. "$(dirname "$0")/helpers.sh"

# ===========================================================================
# Section 0: Static analysis (runs before _mock_home so shim-managed
#            tools like shellcheck can find their real install dirs)
# ===========================================================================

echo "=== ShellCheck ==="

_sc_files=()
while IFS= read -r _tracked; do
  _f="$SHDEPS_DIR/$_tracked"
  [[ -f "$_f" && ! -L "$_f" ]] || continue
  case "$_tracked" in
    *.sh | *.bash)
      _sc_files+=("$_f")
      continue
      ;;
  esac
  IFS= read -r _first <"$_f" || true
  case "$_first" in
    '#!/usr/bin/env bash' | '#!/bin/bash') _sc_files+=("$_f") ;;
  esac
done < <(git -C "$SHDEPS_DIR" ls-tree -r --name-only HEAD)

if [[ "${#_sc_files[@]}" -eq 0 ]]; then
  _fail "shellcheck: no files discovered"
elif _sc_output=$(shellcheck -x -P SCRIPTDIR --exclude=SC1091 "${_sc_files[@]}" 2>&1); then
  _pass "shellcheck: all files clean"
else
  _fail "shellcheck: findings detected"
  while IFS= read -r _line; do
    printf '    %s\n' "$_line" >&2
  done <<<"$_sc_output"
fi

# Set up isolated environment for functional tests
_mock_home
_source_shdeps "$SHDEPS_DIR"

# ===========================================================================
# Section 1: Config parsing
# ===========================================================================

echo "=== Config parsing ==="

# --- Well-formed conf file ---

_test_conf_dir=$(_tmpdir)
cat >"$_test_conf_dir/deps.conf" <<'EOF'
jq        pkg
bat       pkg       apt:batcat
fd        pkg       apt:fdfind     apt:fd-find,dnf:fd-find
cgraf78/ds github:repo
neovim/neovim github:release nvim
nerd-fonts custom
EOF

SHDEPS_CONF_DIR="$_test_conf_dir"
_shdeps_load
_assert_eq "well-formed: entry count" "6" "${#_SHDEPS_DEPS[@]}"
_assert_contains "well-formed: first entry is bat (sorted)" "bat" "${_SHDEPS_DEPS[0]}"
_assert_contains "well-formed: last entry is neovim/neovim (sorted)" "neovim/neovim" "${_SHDEPS_DEPS[4]}"
_assert_contains "well-formed: nerd-fonts after neovim (sorted)" "nerd-fonts" "${_SHDEPS_DEPS[5]}"

# --- Minimal entry (name + method only) ---

rm -f "$_test_conf_dir"/*.conf
cat >"$_test_conf_dir/deps.conf" <<'EOF'
jq  pkg
EOF
_shdeps_load
_assert_eq "minimal entry: count" "1" "${#_SHDEPS_DEPS[@]}"
_assert_eq "minimal entry: content" "jq|pkg" "${_SHDEPS_DEPS[0]}"

# --- Maximal entry (all 5 fields) ---

cat >"$_test_conf_dir/deps.conf" <<'EOF'
fd  pkg  apt:fdfind  apt:fd-find,dnf:fd-find  os:linux,os:macos,host:nas
EOF
_shdeps_load
_assert_eq "maximal entry: count" "1" "${#_SHDEPS_DEPS[@]}"
_assert_contains "maximal entry: has os filter" "os:linux,os:macos" "${_SHDEPS_DEPS[0]}"
_assert_contains "maximal entry: has host filter" "host:nas" "${_SHDEPS_DEPS[0]}"

# --- Comments and blank lines ---

cat >"$_test_conf_dir/deps.conf" <<'EOF'
# This is a comment
   # Indented comment

tool-a  pkg


tool-b  pkg
EOF
_shdeps_load
_assert_eq "comments/blanks: count" "2" "${#_SHDEPS_DEPS[@]}"
_assert_contains "comments/blanks: first" "tool-a" "${_SHDEPS_DEPS[0]}"
_assert_contains "comments/blanks: second" "tool-b" "${_SHDEPS_DEPS[1]}"

# --- Missing config dir ---

SHDEPS_CONF_DIR="$_test_conf_dir/nonexistent"
_shdeps_load
_assert_eq "missing dir: empty deps" "0" "${#_SHDEPS_DEPS[@]}"

# --- Empty config dir (exists but no .conf files) ---

_empty_conf_dir=$(_tmpdir)
SHDEPS_CONF_DIR="$_empty_conf_dir"
_shdeps_load
_assert_eq "empty dir: empty deps" "0" "${#_SHDEPS_DEPS[@]}"

# --- Multiple conf files merged in sorted order ---

_multi_conf_dir=$(_tmpdir)
cat >"$_multi_conf_dir/00-core.conf" <<'EOF'
tool-a  pkg
tool-b  pkg
EOF
cat >"$_multi_conf_dir/50-extras.conf" <<'EOF'
owner/tool-c  github:release
EOF
cat >"$_multi_conf_dir/99-local.conf" <<'EOF'
tool-d  custom
EOF
SHDEPS_CONF_DIR="$_multi_conf_dir"
_shdeps_load
_assert_eq "multi-file: entry count" "4" "${#_SHDEPS_DEPS[@]}"
_assert_contains "multi-file: sorted first" "owner/tool-c" "${_SHDEPS_DEPS[0]}"
_assert_contains "multi-file: sorted second" "tool-a" "${_SHDEPS_DEPS[1]}"
_assert_contains "multi-file: sorted third" "tool-b" "${_SHDEPS_DEPS[2]}"
_assert_contains "multi-file: sorted fourth" "tool-d" "${_SHDEPS_DEPS[3]}"

# --- Non-.conf files ignored ---

_mixed_dir=$(_tmpdir)
cat >"$_mixed_dir/deps.conf" <<'EOF'
tool-a  pkg
EOF
cat >"$_mixed_dir/notes.txt" <<'EOF'
tool-b  pkg
EOF
cat >"$_mixed_dir/deps.conf.bak" <<'EOF'
tool-c  pkg
EOF
SHDEPS_CONF_DIR="$_mixed_dir"
_shdeps_load
_assert_eq "non-conf ignored: count" "1" "${#_SHDEPS_DEPS[@]}"
_assert_contains "non-conf ignored: only .conf loaded" "tool-a" "${_SHDEPS_DEPS[0]}"

# --- Single conf file in dir ---

_single_dir=$(_tmpdir)
cat >"$_single_dir/deps.conf" <<'EOF'
tool-a  pkg
tool-b  pkg
EOF
SHDEPS_CONF_DIR="$_single_dir"
_shdeps_load
_assert_eq "single file: entry count" "2" "${#_SHDEPS_DEPS[@]}"

# --- Public shdeps_load returns count ---

SHDEPS_CONF_DIR="$_single_dir"
count=$(shdeps_load)
_assert_eq "shdeps_load: returns count" "2" "$count"

# --- Dash fields preserved as literal in raw entry ---

rm -f "$_test_conf_dir"/*.conf
cat >"$_test_conf_dir/deps.conf" <<'EOF'
cgraf78/ds  github:repo  -  -
EOF
SHDEPS_CONF_DIR="$_test_conf_dir"
_shdeps_load
_assert_contains "dash fields: preserved in entry" "cgraf78/ds|github:repo|-|-" "${_SHDEPS_DEPS[0]}"

# ===========================================================================
# Section 2: Entry parsing
# ===========================================================================

echo ""
echo "=== Entry parsing ==="

# Ensure pkg manager is detected for platform-qualified cmd resolution
_shdeps_pkg_detect

# --- Full pkg entry with all fields ---

_shdeps_parse "fd|pkg|apt:fdfind|apt:fd-find,dnf:fd-find|os:linux,os:macos"
_assert_eq "parse full: name" "fd" "$_name"
_assert_eq "parse full: method" "pkg" "$_method"
# apt:fdfind is platform-qualified; on brew it resolves to default name "fd"
if [[ "${_SHDEPS_PKG_MGR:-}" == "apt" ]]; then
  _assert_eq "parse full: cmd (apt)" "fdfind" "$_cmd"
else
  _assert_eq "parse full: cmd (non-apt)" "fd" "$_cmd"
fi
_assert_eq "parse full: aliases" "apt:fd-find,dnf:fd-find" "$_aliases"
_assert_eq "parse full: filter" "os:linux,os:macos" "$_filter"

# --- Full github:release entry (name is owner/repo) ---

_shdeps_parse "neovim/neovim|github:release|nvim|-|os:linux,os:macos"
_assert_eq "parse github:release: name" "neovim/neovim" "$_name"
_assert_eq "parse github:release: cmd" "nvim" "$_cmd"
_assert_eq "parse github:release: filter" "os:linux,os:macos" "$_filter"

# --- Dash fields normalize to empty ---

_shdeps_parse "pkg-a|pkg|-|-|-"
_assert_eq "dash normalize: cmd defaults to name" "pkg-a" "$_cmd"
_assert_eq "dash normalize: aliases empty" "" "$_aliases"
_assert_eq "dash normalize: filter empty" "" "$_filter"

# --- Minimal entry (name + method) ---

_shdeps_parse "jq|pkg"
_assert_eq "parse minimal: name" "jq" "$_name"
_assert_eq "parse minimal: method" "pkg" "$_method"
_assert_eq "parse minimal: cmd defaults to name" "jq" "$_cmd"
_assert_eq "parse minimal: aliases empty" "" "$_aliases"

# --- cmd set explicitly ---

_shdeps_parse "neovim/neovim|github:release|nvim"
_assert_eq "parse explicit cmd: name" "neovim/neovim" "$_name"
_assert_eq "parse explicit cmd: cmd" "nvim" "$_cmd"

# --- platform-qualified cmd ---

_SHDEPS_PKG_MGR="apt"
_shdeps_parse "bat|pkg|apt:batcat"
_assert_eq "parse platform cmd (apt): cmd" "batcat" "$_cmd"
_SHDEPS_PKG_MGR="brew"
_shdeps_parse "bat|pkg|apt:batcat"
_assert_eq "parse platform cmd (brew): cmd" "bat" "$_cmd"
_shdeps_pkg_detect

# ===========================================================================
# Section 3: Platform matching
# ===========================================================================

echo ""
echo "=== Platform matching ==="

# Detect current platform for assertions (normalized like shdeps does)
_current_os=$(shdeps_platform)

# --- Empty spec matches all ---

shdeps_platform_match ""
_assert_exit "empty spec: matches" 0 $?

# --- Include list: current platform ---

shdeps_platform_match "$_current_os"
_assert_exit "include: current os matches" 0 $?

# --- Include list: other platform ---

if [[ "$_current_os" == "linux" ]]; then
  rc=0
  shdeps_platform_match "macos" || rc=$?
  _assert_exit "include: other os rejected" 1 "$rc"
else
  rc=0
  shdeps_platform_match "linux" || rc=$?
  _assert_exit "include: other os rejected" 1 "$rc"
fi

# --- Include list: multiple platforms ---

shdeps_platform_match "linux,macos"
_assert_exit "include multi: linux,macos matches" 0 $?

# --- Include list: none matching ---

rc=0
shdeps_platform_match "freebsd,openbsd" || rc=$?
_assert_exit "include: no match rejected" 1 "$rc"

# --- Exclude list: excludes current ---

rc=0
shdeps_platform_match "!${_current_os}" || rc=$?
_assert_exit "exclude: current os excluded" 1 "$rc"

# --- Exclude list: excludes other ---

if [[ "$_current_os" == "linux" ]]; then
  shdeps_platform_match "!macos"
  _assert_exit "exclude: other os not excluded" 0 $?
else
  shdeps_platform_match "!linux"
  _assert_exit "exclude: other os not excluded" 0 $?
fi

# --- Exclude list: multiple excludes, none matching ---

if [[ "$_current_os" == "linux" ]]; then
  shdeps_platform_match "!macos,!freebsd"
  _assert_exit "exclude multi: none matching passes" 0 $?
else
  shdeps_platform_match "!linux,!freebsd"
  _assert_exit "exclude multi: none matching passes" 0 $?
fi

# --- Mixed: exclude takes priority ---

rc=0
shdeps_platform_match "${_current_os},!${_current_os}" || rc=$?
_assert_exit "mixed: exclude overrides include" 1 "$rc"

# --- Mixed: included and not excluded ---

if [[ "$_current_os" == "linux" ]]; then
  shdeps_platform_match "linux,!macos"
  _assert_exit "mixed: included and not excluded" 0 $?
else
  shdeps_platform_match "macos,!linux"
  _assert_exit "mixed: included and not excluded" 0 $?
fi

# --- Mixed: not in include list ---

if [[ "$_current_os" == "linux" ]]; then
  rc=0
  shdeps_platform_match "macos,!freebsd" || rc=$?
  _assert_exit "mixed: not in include list" 1 "$rc"
else
  rc=0
  shdeps_platform_match "linux,!freebsd" || rc=$?
  _assert_exit "mixed: not in include list" 1 "$rc"
fi

# ===========================================================================
# Section 3b: Host matching
# ===========================================================================

echo ""
echo "=== Host matching ==="

# Detect current hostname for assertions
_current_host=$(hostname -s 2>/dev/null || hostname 2>/dev/null)
_current_host="${_current_host,,}"

# --- Empty spec matches all ---

shdeps_host_match ""
_assert_exit "empty spec: matches" 0 $?

# --- Include list: current host ---

shdeps_host_match "$_current_host"
_assert_exit "include: current host matches" 0 $?

# --- Include list: other host ---

rc=0
shdeps_host_match "nonexistent-host-xyz" || rc=$?
_assert_exit "include: other host rejected" 1 "$rc"

# --- Include list: multiple hosts ---

shdeps_host_match "other-host,$_current_host"
_assert_exit "include multi: current host in list matches" 0 $?

# --- Include list: none matching ---

rc=0
shdeps_host_match "host-a,host-b" || rc=$?
_assert_exit "include: no match rejected" 1 "$rc"

# --- Exclude list: excludes current ---

rc=0
shdeps_host_match "!${_current_host}" || rc=$?
_assert_exit "exclude: current host excluded" 1 "$rc"

# --- Exclude list: excludes other ---

shdeps_host_match "!nonexistent-host-xyz"
_assert_exit "exclude: other host not excluded" 0 $?

# --- Exclude list: multiple excludes, none matching ---

shdeps_host_match "!host-a,!host-b"
_assert_exit "exclude multi: none matching passes" 0 $?

# --- Mixed: exclude takes priority ---

rc=0
shdeps_host_match "${_current_host},!${_current_host}" || rc=$?
_assert_exit "mixed: exclude overrides include" 1 "$rc"

# --- Mixed: included and not excluded ---

shdeps_host_match "${_current_host},!other-host"
_assert_exit "mixed: included and not excluded" 0 $?

# --- Mixed: not in include list ---

rc=0
shdeps_host_match "other-host,!nonexistent" || rc=$?
_assert_exit "mixed: not in include list" 1 "$rc"

# --- Case-insensitive matching ---

_upper_host="${_current_host^^}"
shdeps_host_match "$_upper_host"
_assert_exit "case-insensitive: uppercase spec matches" 0 $?

rc=0
shdeps_host_match "!${_upper_host}" || rc=$?
_assert_exit "case-insensitive: uppercase exclude works" 1 "$rc"

# ===========================================================================
# Section 3c: Entry parsing with filter field
# ===========================================================================

echo ""
echo "=== Entry parsing (filter field) ==="

# --- Full entry with host filter ---

_shdeps_parse "openai/codex|github:release|codex|-|host:nas"
_assert_eq "parse filter: name" "openai/codex" "$_name"
_assert_eq "parse filter: filter" "host:nas" "$_filter"

# --- Dash filter normalizes to empty ---

_shdeps_parse "jq|pkg|-|-|-"
_assert_eq "dash filter: empty" "" "$_filter"

# --- Missing filter field → empty ---

_shdeps_parse "jq|pkg"
_assert_eq "missing filter: empty" "" "$_filter"

# --- Maximal entry with hosts ---

rm -f "$_test_conf_dir"/*.conf
cat >"$_test_conf_dir/deps.conf" <<'EOF'
openai/codex  github:release  -  -  host:nas,host:taylor
EOF
SHDEPS_CONF_DIR="$_test_conf_dir"
_shdeps_load
_assert_contains "maximal with hosts: has hosts" "host:nas,host:taylor" "${_SHDEPS_DEPS[0]}"

# ===========================================================================
# Section 3b: Short name helper
# ===========================================================================

echo ""
echo "=== Short name ==="

result=$(_shdeps_short_name "neovim/neovim")
_assert_eq "short_name: owner/repo" "neovim" "$result"

result=$(_shdeps_short_name "bat")
_assert_eq "short_name: bare name" "bat" "$result"

result=$(_shdeps_short_name "zsh-users/zsh-autosuggestions")
_assert_eq "short_name: hyphenated" "zsh-autosuggestions" "$result"

# ===========================================================================
# Section 3c: Filter matching
# ===========================================================================

echo ""
echo "=== Filter matching ==="

# --- Empty filter matches all ---

rc=0
_shdeps_filter_match "" || rc=$?
_assert_eq "filter: empty matches" "0" "$rc"

# --- os: filter ---

rc=0
_shdeps_filter_match "os:$(shdeps_platform)" || rc=$?
_assert_eq "filter: current os matches" "0" "$rc"

if [[ "$(shdeps_platform)" == "macos" ]]; then
  _other_os="linux"
else
  _other_os="macos"
fi

rc=0
_shdeps_filter_match "os:$_other_os" || rc=$?
_assert_eq "filter: other os rejected" "1" "$rc"

# --- host: filter ---

_current_host=$(hostname -s 2>/dev/null || hostname 2>/dev/null)
_current_host="${_current_host,,}"

rc=0
_shdeps_filter_match "host:$_current_host" || rc=$?
_assert_eq "filter: current host matches" "0" "$rc"

rc=0
_shdeps_filter_match "host:nonexistent-host-xyz" || rc=$?
_assert_eq "filter: other host rejected" "2" "$rc"

# --- Mixed os + host ---

rc=0
_shdeps_filter_match "os:$(shdeps_platform),host:$_current_host" || rc=$?
_assert_eq "filter: mixed both match" "0" "$rc"

rc=0
_shdeps_filter_match "os:$_other_os,host:$_current_host" || rc=$?
_assert_eq "filter: mixed os fails" "1" "$rc"

rc=0
_shdeps_filter_match "os:$(shdeps_platform),host:nonexistent-host-xyz" || rc=$?
_assert_eq "filter: mixed host fails" "2" "$rc"

# --- Negation ---

rc=0
_shdeps_filter_match "os:!$_other_os" || rc=$?
_assert_eq "filter: negated other os passes" "0" "$rc"

rc=0
_shdeps_filter_match "os:!$(shdeps_platform)" || rc=$?
_assert_eq "filter: negated current os fails" "1" "$rc"

rc=0
_shdeps_filter_match "host:!nonexistent-host-xyz" || rc=$?
_assert_eq "filter: negated other host passes" "0" "$rc"

rc=0
_shdeps_filter_match "host:!$_current_host" || rc=$?
_assert_eq "filter: negated current host fails" "2" "$rc"

# ===========================================================================
# Section 4: Package manager detection and resolution
# ===========================================================================

echo ""
echo "=== Package manager ==="

# --- _shdeps_pkg_detect with mock commands ---

_mock_bin_dir=$(_mock_bin)
export PATH="$_mock_bin_dir:$PATH"

# Mock brew on Darwin-like detection: _shdeps_pkg_detect checks uname first
# so we test the resolution and queuing logic directly instead.

# --- _shdeps_pkg_detect: mock zypper ---
# Use an isolated PATH with only the mock binary so real apt/dnf/pacman
# don't shadow zypper (which has lower priority in the detect chain).

_zypper_mock_dir=$(_mock_bin)
cat >"$_zypper_mock_dir/zypper" <<'MOCK'
#!/bin/bash
exit 0
MOCK
chmod +x "$_zypper_mock_dir/zypper"
_saved_path="$PATH"
PATH="$_zypper_mock_dir"
_shdeps_pkg_detect
_assert_eq "pkg_detect: finds zypper" "zypper" "$_SHDEPS_PKG_MGR"
PATH="$_saved_path"

# --- _shdeps_pkg_detect: mock apk ---

_apk_mock_dir=$(_mock_bin)
cat >"$_apk_mock_dir/apk" <<'MOCK'
#!/bin/bash
exit 0
MOCK
chmod +x "$_apk_mock_dir/apk"
_saved_path="$PATH"
PATH="$_apk_mock_dir"
_shdeps_pkg_detect
_assert_eq "pkg_detect: finds apk" "apk" "$_SHDEPS_PKG_MGR"
PATH="$_saved_path"

# Restore pkg manager for remaining tests
_shdeps_pkg_detect

# --- _shdeps_resolve_override: no overrides → returns name ---

_SHDEPS_PKG_MGR="apt"
result=$(_shdeps_resolve_override "fd" "")
_assert_eq "resolve: no overrides returns name" "fd" "$result"

# --- _shdeps_resolve_override: matching override ---

result=$(_shdeps_resolve_override "fd" "apt:fd-find,dnf:fd-find")
_assert_eq "resolve: apt override" "fd-find" "$result"

# --- _shdeps_resolve_override: non-matching override ---

_SHDEPS_PKG_MGR="pacman"
result=$(_shdeps_resolve_override "fd" "apt:fd-find,dnf:fd-find")
_assert_eq "resolve: no matching mgr returns name" "fd" "$result"

# --- _shdeps_resolve_override: NONE sentinel ---

_SHDEPS_PKG_MGR="apt"
result=$(_shdeps_resolve_override "nerd-fonts" "apt:NONE,brew:font-hack-nerd-font")
_assert_eq "resolve: NONE sentinel" "NONE" "$result"

# --- _shdeps_resolve_override: brew override ---

_SHDEPS_PKG_MGR="brew"
result=$(_shdeps_resolve_override "nerd-fonts" "apt:NONE,brew:font-hack-nerd-font")
_assert_eq "resolve: brew override" "font-hack-nerd-font" "$result"

# --- _shdeps_resolve_override: multiple overrides, first match wins ---

_SHDEPS_PKG_MGR="dnf"
result=$(_shdeps_resolve_override "bat" "apt:bat,dnf:bat-extra,pacman:bat")
_assert_eq "resolve: dnf gets its override" "bat-extra" "$result"

# --- _shdeps_resolve_override: zypper override ---

_SHDEPS_PKG_MGR="zypper"
result=$(_shdeps_resolve_override "fd" "zypper:fd,apt:fd-find")
_assert_eq "resolve: zypper override" "fd" "$result"

# --- _shdeps_resolve_override: apk override ---

_SHDEPS_PKG_MGR="apk"
result=$(_shdeps_resolve_override "bat" "apk:bat-extra,apt:bat")
_assert_eq "resolve: apk override" "bat-extra" "$result"

# --- _shdeps_resolve_override: zypper/apk fallback to name ---

_SHDEPS_PKG_MGR="zypper"
result=$(_shdeps_resolve_override "jq" "apt:jq-tools")
_assert_eq "resolve: zypper no match returns name" "jq" "$result"

_SHDEPS_PKG_MGR="apk"
result=$(_shdeps_resolve_override "jq" "apt:jq-tools")
_assert_eq "resolve: apk no match returns name" "jq" "$result"

# --- _shdeps_pkg_queue: NONE skips silently ---

_SHDEPS_PKG_MGR="apt"
_SHDEPS_PKG_BATCH=()
_SHDEPS_PKG_BATCH_NAMES=()
_shdeps_pkg_queue "nerd-fonts" "apt:NONE"
_assert_eq "queue: NONE skips" "0" "${#_SHDEPS_PKG_BATCH[@]}"

# --- _shdeps_pkg_queue: resolved package added to batch ---

# Mock _shdeps_pkg_available to always succeed for testing
# shellcheck disable=SC2317,SC2329  # invoked indirectly via _shdeps_pkg_queue
_shdeps_pkg_available() { return 0; }
_SHDEPS_PKG_BATCH=()
_SHDEPS_PKG_BATCH_NAMES=()
_shdeps_pkg_queue "fd" "apt:fd-find"
_assert_eq "queue: adds resolved pkg" "1" "${#_SHDEPS_PKG_BATCH[@]}"
_assert_eq "queue: resolved name" "fd-find" "${_SHDEPS_PKG_BATCH[0]}"
_assert_eq "queue: original name" "fd" "${_SHDEPS_PKG_BATCH_NAMES[0]}"

# --- _shdeps_pkg_queue: multiple packages batch ---

_shdeps_pkg_queue "jq" ""
_assert_eq "queue: batch grows" "2" "${#_SHDEPS_PKG_BATCH[@]}"
_assert_eq "queue: second pkg" "jq" "${_SHDEPS_PKG_BATCH[1]}"

# --- _shdeps_pkg_queue: unavailable package skipped ---

# shellcheck disable=SC2317,SC2329  # invoked indirectly via _shdeps_pkg_queue
_shdeps_pkg_available() { return 1; }
_SHDEPS_PKG_BATCH=()
_SHDEPS_PKG_BATCH_NAMES=()
_shdeps_pkg_queue "nonexistent-tool" ""
_assert_eq "queue: unavailable skipped" "0" "${#_SHDEPS_PKG_BATCH[@]}"

# Restore real _shdeps_pkg_available
_source_shdeps "$SHDEPS_DIR"

# --- _shdeps_pkg_detect: detects real system manager ---
# Just verify it sets something (or empty on unusual systems)

_shdeps_pkg_detect
_assert_match "pkg_detect: sets a known value" "^(brew|apt|dnf|pacman|zypper|apk)?$" "$_SHDEPS_PKG_MGR"

# --- _shdeps_check_prereqs: all pkg deps installed → NEEDED=0 ---

_cpn_dir=$(_tmpdir)
_cpn_bin=$(_mock_bin)
