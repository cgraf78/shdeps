#!/usr/bin/env bash
# shellcheck disable=SC2154,SC2034
# SC2154: variables set by sourced shdeps.sh (_name, _method, _SHDEPS_DEPS, etc.)
# SC2034: variables read by sourced shdeps.sh (SHDEPS_CONF_DIR, SHDEPS_FORCE, etc.)
#
# shdeps-test — comprehensive test suite for shdeps.sh
#
# Usage: ./test/shdeps-test
#
# Tests are organized by section matching the library's architecture.
# Each section uses echo "=== Section Name ===" headers.
# All tests run in an isolated mock HOME to avoid touching real system.

set -uo pipefail

SHDEPS_DIR="$(cd "$(dirname "$0")/.." && pwd)"

# shellcheck source=helpers.sh
. "$(dirname "$0")/helpers.sh"

# Set up isolated environment
_mock_home
_source_shdeps "$SHDEPS_DIR"

# ===========================================================================
# Section 0: Static analysis
# ===========================================================================

echo "=== ShellCheck ==="

_sc_files=()
while IFS= read -r _tracked; do
  _f="$SHDEPS_DIR/$_tracked"
  [[ -f "$_f" && ! -L "$_f" ]] || continue
  case "$_tracked" in
    *.sh | *.bash) _sc_files+=("$_f"); continue ;;
  esac
  IFS= read -r _first <"$_f" || true
  case "$_first" in
    '#!/usr/bin/env bash' | '#!/bin/bash') _sc_files+=("$_f") ;;
  esac
done < <(git -C "$SHDEPS_DIR" ls-tree -r --name-only HEAD)

if [[ "${#_sc_files[@]}" -eq 0 ]]; then
  _fail "shellcheck: no files discovered"
elif _sc_output=$(shellcheck -x -P SCRIPTDIR "${_sc_files[@]}" 2>&1); then
  _pass "shellcheck: all files clean"
else
  _fail "shellcheck: findings detected"
  while IFS= read -r _line; do
    printf '    %s\n' "$_line" >&2
  done <<<"$_sc_output"
fi

# ===========================================================================
# Section 1: Config parsing
# ===========================================================================

echo "=== Config parsing ==="

# --- Well-formed conf file ---

_test_conf_dir=$(_tmpdir)
cat >"$_test_conf_dir/deps.conf" <<'EOF'
jq        pkg
bat       pkg       bat    batcat
fd        pkg       fd     fdfind     apt:fd-find,dnf:fd-find
ds        git       -      -          cgraf78/ds.git
neovim    binary    nvim   -          neovim/neovim
nerd-fonts custom
EOF

SHDEPS_CONF_DIR="$_test_conf_dir"
_shdeps_load
_assert_eq "well-formed: entry count" "6" "${#_SHDEPS_DEPS[@]}"
_assert_contains "well-formed: first entry is bat (sorted)" "bat" "${_SHDEPS_DEPS[0]}"
_assert_contains "well-formed: last entry is neovim (sorted)" "neovim" "${_SHDEPS_DEPS[4]}"
_assert_contains "well-formed: nerd-fonts after neovim (sorted)" "nerd-fonts" "${_SHDEPS_DEPS[5]}"

# --- Minimal entry (name + method only) ---

rm -f "$_test_conf_dir"/*.conf
cat >"$_test_conf_dir/deps.conf" <<'EOF'
jq  pkg
EOF
_shdeps_load
_assert_eq "minimal entry: count" "1" "${#_SHDEPS_DEPS[@]}"
_assert_eq "minimal entry: content" "jq|pkg" "${_SHDEPS_DEPS[0]}"

# --- Maximal entry (all 7 fields) ---

cat >"$_test_conf_dir/deps.conf" <<'EOF'
fd  pkg  fd  fdfind  apt:fd-find,dnf:fd-find  linux,macos  nas
EOF
_shdeps_load
_assert_eq "maximal entry: count" "1" "${#_SHDEPS_DEPS[@]}"
_assert_contains "maximal entry: has platforms" "linux,macos" "${_SHDEPS_DEPS[0]}"
_assert_contains "maximal entry: has hosts" "nas" "${_SHDEPS_DEPS[0]}"

# --- Comments and blank lines ---

cat >"$_test_conf_dir/deps.conf" <<'EOF'
# This is a comment
   # Indented comment

tool-a  pkg


tool-b  pkg
EOF
_shdeps_load
_assert_eq "comments/blanks: count" "2" "${#_SHDEPS_DEPS[@]}"
_assert_contains "comments/blanks: first" "tool-a" "${_SHDEPS_DEPS[0]}"
_assert_contains "comments/blanks: second" "tool-b" "${_SHDEPS_DEPS[1]}"

# --- Missing config dir ---

SHDEPS_CONF_DIR="$_test_conf_dir/nonexistent"
_shdeps_load
_assert_eq "missing dir: empty deps" "0" "${#_SHDEPS_DEPS[@]}"

# --- Empty config dir (exists but no .conf files) ---

_empty_conf_dir=$(_tmpdir)
SHDEPS_CONF_DIR="$_empty_conf_dir"
_shdeps_load
_assert_eq "empty dir: empty deps" "0" "${#_SHDEPS_DEPS[@]}"

# --- Multiple conf files merged in sorted order ---

_multi_conf_dir=$(_tmpdir)
cat >"$_multi_conf_dir/00-core.conf" <<'EOF'
tool-a  pkg
tool-b  pkg
EOF
cat >"$_multi_conf_dir/50-extras.conf" <<'EOF'
tool-c  binary  -  -  owner/tool-c
EOF
cat >"$_multi_conf_dir/99-local.conf" <<'EOF'
tool-d  custom
EOF
SHDEPS_CONF_DIR="$_multi_conf_dir"
_shdeps_load
_assert_eq "multi-file: entry count" "4" "${#_SHDEPS_DEPS[@]}"
_assert_contains "multi-file: sorted first" "tool-a" "${_SHDEPS_DEPS[0]}"
_assert_contains "multi-file: sorted second" "tool-b" "${_SHDEPS_DEPS[1]}"
_assert_contains "multi-file: sorted third" "tool-c" "${_SHDEPS_DEPS[2]}"
_assert_contains "multi-file: sorted fourth" "tool-d" "${_SHDEPS_DEPS[3]}"

# --- Non-.conf files ignored ---

_mixed_dir=$(_tmpdir)
cat >"$_mixed_dir/deps.conf" <<'EOF'
tool-a  pkg
EOF
cat >"$_mixed_dir/notes.txt" <<'EOF'
tool-b  pkg
EOF
cat >"$_mixed_dir/deps.conf.bak" <<'EOF'
tool-c  pkg
EOF
SHDEPS_CONF_DIR="$_mixed_dir"
_shdeps_load
_assert_eq "non-conf ignored: count" "1" "${#_SHDEPS_DEPS[@]}"
_assert_contains "non-conf ignored: only .conf loaded" "tool-a" "${_SHDEPS_DEPS[0]}"

# --- Single conf file in dir ---

_single_dir=$(_tmpdir)
cat >"$_single_dir/deps.conf" <<'EOF'
tool-a  pkg
tool-b  pkg
EOF
SHDEPS_CONF_DIR="$_single_dir"
_shdeps_load
_assert_eq "single file: entry count" "2" "${#_SHDEPS_DEPS[@]}"

# --- Public shdeps_load returns count ---

SHDEPS_CONF_DIR="$_single_dir"
count=$(shdeps_load)
_assert_eq "shdeps_load: returns count" "2" "$count"

# --- Dash fields preserved as literal in raw entry ---

rm -f "$_test_conf_dir"/*.conf
cat >"$_test_conf_dir/deps.conf" <<'EOF'
ds  git  -  -  cgraf78/ds.git
EOF
SHDEPS_CONF_DIR="$_test_conf_dir"
_shdeps_load
_assert_contains "dash fields: preserved in entry" "ds|git|-|-|cgraf78/ds.git" "${_SHDEPS_DEPS[0]}"

# ===========================================================================
# Section 2: Entry parsing
# ===========================================================================

echo ""
echo "=== Entry parsing ==="

# --- Full pkg entry with all fields ---

_shdeps_parse "fd|pkg|fd|fdfind|apt:fd-find,dnf:fd-find|linux,macos"
_assert_eq "parse full: name" "fd" "$_name"
_assert_eq "parse full: method" "pkg" "$_method"
_assert_eq "parse full: cmd" "fd" "$_cmd"
_assert_eq "parse full: cmd_alt" "fdfind" "$_cmd_alt"
_assert_eq "parse full: source" "apt:fd-find,dnf:fd-find" "$_source"
_assert_eq "parse full: platforms" "linux,macos" "$_platforms"
_assert_eq "parse full: hosts empty when absent" "" "$_hosts"

# --- Full binary entry (source is owner/repo) ---

_shdeps_parse "neovim|binary|nvim|-|neovim/neovim|linux,macos"
_assert_eq "parse binary: source" "neovim/neovim" "$_source"
_assert_eq "parse binary: platforms" "linux,macos" "$_platforms"

# --- Dash fields normalize to empty ---

_shdeps_parse "pkg-a|pkg|-|-|-"
_assert_eq "dash normalize: cmd defaults to name" "pkg-a" "$_cmd"
_assert_eq "dash normalize: cmd_alt empty" "" "$_cmd_alt"
_assert_eq "dash normalize: source empty" "" "$_source"
_assert_eq "dash normalize: platforms empty" "" "$_platforms"
_assert_eq "dash normalize: hosts empty" "" "$_hosts"

# --- Minimal entry (name + method) ---

_shdeps_parse "jq|pkg"
_assert_eq "parse minimal: name" "jq" "$_name"
_assert_eq "parse minimal: method" "pkg" "$_method"
_assert_eq "parse minimal: cmd defaults to name" "jq" "$_cmd"
_assert_eq "parse minimal: cmd_alt empty" "" "$_cmd_alt"
_assert_eq "parse minimal: source empty" "" "$_source"

# --- cmd set explicitly ---

_shdeps_parse "neovim|binary|nvim"
_assert_eq "parse explicit cmd: name" "neovim" "$_name"
_assert_eq "parse explicit cmd: cmd" "nvim" "$_cmd"

# --- cmd_alt set ---

_shdeps_parse "bat|pkg|bat|batcat"
_assert_eq "parse cmd_alt: cmd" "bat" "$_cmd"
_assert_eq "parse cmd_alt: cmd_alt" "batcat" "$_cmd_alt"

# ===========================================================================
# Section 3: Platform matching
# ===========================================================================

echo ""
echo "=== Platform matching ==="

# Detect current platform for assertions (normalized like shdeps does)
_current_os=$(uname -s | tr '[:upper:]' '[:lower:]')
if [[ "$_current_os" == "darwin" ]]; then _current_os="macos"; fi

# --- Empty spec matches all ---

shdeps_platform_match ""
_assert_exit "empty spec: matches" 0 $?

# --- Include list: current platform ---

shdeps_platform_match "$_current_os"
_assert_exit "include: current os matches" 0 $?

# --- Include list: other platform ---

if [[ "$_current_os" == "linux" ]]; then
  rc=0; shdeps_platform_match "macos" || rc=$?
  _assert_exit "include: other os rejected" 1 "$rc"
else
  rc=0; shdeps_platform_match "linux" || rc=$?
  _assert_exit "include: other os rejected" 1 "$rc"
fi

# --- Include list: multiple platforms ---

shdeps_platform_match "linux,macos"
_assert_exit "include multi: linux,macos matches" 0 $?

# --- Include list: none matching ---

rc=0; shdeps_platform_match "freebsd,openbsd" || rc=$?
_assert_exit "include: no match rejected" 1 "$rc"

# --- Exclude list: excludes current ---

rc=0; shdeps_platform_match "!${_current_os}" || rc=$?
_assert_exit "exclude: current os excluded" 1 "$rc"

# --- Exclude list: excludes other ---

if [[ "$_current_os" == "linux" ]]; then
  shdeps_platform_match "!macos"
  _assert_exit "exclude: other os not excluded" 0 $?
else
  shdeps_platform_match "!linux"
  _assert_exit "exclude: other os not excluded" 0 $?
fi

# --- Exclude list: multiple excludes, none matching ---

if [[ "$_current_os" == "linux" ]]; then
  shdeps_platform_match "!macos,!freebsd"
  _assert_exit "exclude multi: none matching passes" 0 $?
else
  shdeps_platform_match "!linux,!freebsd"
  _assert_exit "exclude multi: none matching passes" 0 $?
fi

# --- Mixed: exclude takes priority ---

rc=0; shdeps_platform_match "${_current_os},!${_current_os}" || rc=$?
_assert_exit "mixed: exclude overrides include" 1 "$rc"

# --- Mixed: included and not excluded ---

if [[ "$_current_os" == "linux" ]]; then
  shdeps_platform_match "linux,!macos"
  _assert_exit "mixed: included and not excluded" 0 $?
else
  shdeps_platform_match "macos,!linux"
  _assert_exit "mixed: included and not excluded" 0 $?
fi

# --- Mixed: not in include list ---

if [[ "$_current_os" == "linux" ]]; then
  rc=0; shdeps_platform_match "macos,!freebsd" || rc=$?
  _assert_exit "mixed: not in include list" 1 "$rc"
else
  rc=0; shdeps_platform_match "linux,!freebsd" || rc=$?
  _assert_exit "mixed: not in include list" 1 "$rc"
fi

# ===========================================================================
# Section 3b: Host matching
# ===========================================================================

echo ""
echo "=== Host matching ==="

# Detect current hostname for assertions
_current_host=$(hostname -s 2>/dev/null || hostname 2>/dev/null)
_current_host="${_current_host,,}"

# --- Empty spec matches all ---

shdeps_host_match ""
_assert_exit "empty spec: matches" 0 $?

# --- Include list: current host ---

shdeps_host_match "$_current_host"
_assert_exit "include: current host matches" 0 $?

# --- Include list: other host ---

rc=0; shdeps_host_match "nonexistent-host-xyz" || rc=$?
_assert_exit "include: other host rejected" 1 "$rc"

# --- Include list: multiple hosts ---

shdeps_host_match "other-host,$_current_host"
_assert_exit "include multi: current host in list matches" 0 $?

# --- Include list: none matching ---

rc=0; shdeps_host_match "host-a,host-b" || rc=$?
_assert_exit "include: no match rejected" 1 "$rc"

# --- Exclude list: excludes current ---

rc=0; shdeps_host_match "!${_current_host}" || rc=$?
_assert_exit "exclude: current host excluded" 1 "$rc"

# --- Exclude list: excludes other ---

shdeps_host_match "!nonexistent-host-xyz"
_assert_exit "exclude: other host not excluded" 0 $?

# --- Exclude list: multiple excludes, none matching ---

shdeps_host_match "!host-a,!host-b"
_assert_exit "exclude multi: none matching passes" 0 $?

# --- Mixed: exclude takes priority ---

rc=0; shdeps_host_match "${_current_host},!${_current_host}" || rc=$?
_assert_exit "mixed: exclude overrides include" 1 "$rc"

# --- Mixed: included and not excluded ---

shdeps_host_match "${_current_host},!other-host"
_assert_exit "mixed: included and not excluded" 0 $?

# --- Mixed: not in include list ---

rc=0; shdeps_host_match "other-host,!nonexistent" || rc=$?
_assert_exit "mixed: not in include list" 1 "$rc"

# --- Case-insensitive matching ---

_upper_host="${_current_host^^}"
shdeps_host_match "$_upper_host"
_assert_exit "case-insensitive: uppercase spec matches" 0 $?

rc=0; shdeps_host_match "!${_upper_host}" || rc=$?
_assert_exit "case-insensitive: uppercase exclude works" 1 "$rc"

# ===========================================================================
# Section 3c: Entry parsing with hosts field
# ===========================================================================

echo ""
echo "=== Entry parsing (hosts field) ==="

# --- Full entry with all 7 fields ---

_shdeps_parse "codex|binary|codex|-|openai/codex|-|nas"
_assert_eq "parse hosts: name" "codex" "$_name"
_assert_eq "parse hosts: hosts" "nas" "$_hosts"

# --- Dash hosts normalize to empty ---

_shdeps_parse "jq|pkg|-|-|-|-|-"
_assert_eq "dash hosts: empty" "" "$_hosts"

# --- Missing hosts field → empty ---

_shdeps_parse "jq|pkg"
_assert_eq "missing hosts: empty" "" "$_hosts"

# --- Maximal entry with hosts ---

rm -f "$_test_conf_dir"/*.conf
cat >"$_test_conf_dir/deps.conf" <<'EOF'
codex  binary  -  -  openai/codex  -  nas,taylor
EOF
SHDEPS_CONF_DIR="$_test_conf_dir"
_shdeps_load
_assert_contains "maximal with hosts: has hosts" "nas,taylor" "${_SHDEPS_DEPS[0]}"

# ===========================================================================
# Section 4: Package manager detection and resolution
# ===========================================================================

echo ""
echo "=== Package manager ==="

# --- _shdeps_pkg_detect with mock commands ---

_mock_bin_dir=$(_mock_bin)
export PATH="$_mock_bin_dir:$PATH"

# Mock brew on Darwin-like detection: _shdeps_pkg_detect checks uname first
# so we test the resolution and queuing logic directly instead.

# --- _shdeps_pkg_resolve: no overrides → returns name ---

_SHDEPS_PKG_MGR="apt"
result=$(_shdeps_pkg_resolve "fd" "")
_assert_eq "resolve: no overrides returns name" "fd" "$result"

# --- _shdeps_pkg_resolve: matching override ---

result=$(_shdeps_pkg_resolve "fd" "apt:fd-find,dnf:fd-find")
_assert_eq "resolve: apt override" "fd-find" "$result"

# --- _shdeps_pkg_resolve: non-matching override ---

_SHDEPS_PKG_MGR="pacman"
result=$(_shdeps_pkg_resolve "fd" "apt:fd-find,dnf:fd-find")
_assert_eq "resolve: no matching mgr returns name" "fd" "$result"

# --- _shdeps_pkg_resolve: NONE sentinel ---

_SHDEPS_PKG_MGR="apt"
result=$(_shdeps_pkg_resolve "nerd-fonts" "apt:NONE,brew:font-hack-nerd-font")
_assert_eq "resolve: NONE sentinel" "NONE" "$result"

# --- _shdeps_pkg_resolve: brew override ---

_SHDEPS_PKG_MGR="brew"
result=$(_shdeps_pkg_resolve "nerd-fonts" "apt:NONE,brew:font-hack-nerd-font")
_assert_eq "resolve: brew override" "font-hack-nerd-font" "$result"

# --- _shdeps_pkg_resolve: multiple overrides, first match wins ---

_SHDEPS_PKG_MGR="dnf"
result=$(_shdeps_pkg_resolve "bat" "apt:bat,dnf:bat-extra,pacman:bat")
_assert_eq "resolve: dnf gets its override" "bat-extra" "$result"

# --- _shdeps_pkg_queue: NONE skips silently ---

_SHDEPS_PKG_MGR="apt"
_SHDEPS_PKG_BATCH=()
_SHDEPS_PKG_BATCH_NAMES=()
_shdeps_pkg_queue "nerd-fonts" "apt:NONE"
_assert_eq "queue: NONE skips" "0" "${#_SHDEPS_PKG_BATCH[@]}"

# --- _shdeps_pkg_queue: resolved package added to batch ---

# Mock _shdeps_pkg_available to always succeed for testing
# shellcheck disable=SC2317,SC2329  # invoked indirectly via _shdeps_pkg_queue
_shdeps_pkg_available() { return 0; }
_SHDEPS_PKG_BATCH=()
_SHDEPS_PKG_BATCH_NAMES=()
_shdeps_pkg_queue "fd" "apt:fd-find"
_assert_eq "queue: adds resolved pkg" "1" "${#_SHDEPS_PKG_BATCH[@]}"
_assert_eq "queue: resolved name" "fd-find" "${_SHDEPS_PKG_BATCH[0]}"
_assert_eq "queue: original name" "fd" "${_SHDEPS_PKG_BATCH_NAMES[0]}"

# --- _shdeps_pkg_queue: multiple packages batch ---

_shdeps_pkg_queue "jq" ""
_assert_eq "queue: batch grows" "2" "${#_SHDEPS_PKG_BATCH[@]}"
_assert_eq "queue: second pkg" "jq" "${_SHDEPS_PKG_BATCH[1]}"

# --- _shdeps_pkg_queue: unavailable package skipped ---

# shellcheck disable=SC2317,SC2329  # invoked indirectly via _shdeps_pkg_queue
_shdeps_pkg_available() { return 1; }
_SHDEPS_PKG_BATCH=()
_SHDEPS_PKG_BATCH_NAMES=()
_shdeps_pkg_queue "nonexistent-tool" ""
_assert_eq "queue: unavailable skipped" "0" "${#_SHDEPS_PKG_BATCH[@]}"

# Restore real _shdeps_pkg_available
_source_shdeps "$SHDEPS_DIR"

# --- _shdeps_pkg_detect: detects real system manager ---
# Just verify it sets something (or empty on unusual systems)

_shdeps_pkg_detect
_assert_match "pkg_detect: sets a known value" "^(brew|apt|dnf|pacman)?$" "$_SHDEPS_PKG_MGR"

# --- _shdeps_check_pkg_needed: all deps installed → 0 ---

_cpn_dir=$(_tmpdir)
_cpn_bin=$(_mock_bin)
cat >"$_cpn_dir/deps.conf" <<'EOF'
tool-a  pkg
tool-b  pkg
EOF
# Create mock commands so _shdeps_exists finds them
printf '#!/bin/sh\n' >"$_cpn_bin/tool-a" && chmod +x "$_cpn_bin/tool-a"
printf '#!/bin/sh\n' >"$_cpn_bin/tool-b" && chmod +x "$_cpn_bin/tool-b"
_saved_path="$PATH"
export PATH="$_cpn_bin:$PATH"
SHDEPS_CONF_DIR="$_cpn_dir" _shdeps_load
_SHDEPS_PKG_MGR="dnf"
unset _SHDEPS_PKG_INSTALL_NEEDED
_shdeps_check_pkg_needed
_assert_eq "check_pkg_needed: all installed → 0" "0" "$_SHDEPS_PKG_INSTALL_NEEDED"
export PATH="$_saved_path"

# --- _shdeps_check_pkg_needed: missing dep → 1 ---

cat >"$_cpn_dir/deps.conf" <<'EOF'
tool-a  pkg
missing-tool  pkg
EOF
SHDEPS_CONF_DIR="$_cpn_dir" _shdeps_load
unset _SHDEPS_PKG_INSTALL_NEEDED
_shdeps_check_pkg_needed
_assert_eq "check_pkg_needed: missing dep → 1" "1" "$_SHDEPS_PKG_INSTALL_NEEDED"

# --- _shdeps_check_pkg_needed: skips non-pkg methods ---

cat >"$_cpn_dir/deps.conf" <<'EOF'
my-tool  git  -  -  user/repo
EOF
SHDEPS_CONF_DIR="$_cpn_dir" _shdeps_load
unset _SHDEPS_PKG_INSTALL_NEEDED
_shdeps_check_pkg_needed
_assert_eq "check_pkg_needed: skips git method" "0" "$_SHDEPS_PKG_INSTALL_NEEDED"

# --- _shdeps_check_pkg_needed: skips when pkg manager is brew ---

cat >"$_cpn_dir/deps.conf" <<'EOF'
missing-tool  pkg
EOF
SHDEPS_CONF_DIR="$_cpn_dir" _shdeps_load
_SHDEPS_PKG_MGR="brew"
unset _SHDEPS_PKG_INSTALL_NEEDED
_shdeps_check_pkg_needed
_assert_eq "check_pkg_needed: brew → 0" "0" "$_SHDEPS_PKG_INSTALL_NEEDED"

# --- _shdeps_check_pkg_needed: skips when no pkg manager ---

_SHDEPS_PKG_MGR=""
unset _SHDEPS_PKG_INSTALL_NEEDED
_shdeps_check_pkg_needed
_assert_eq "check_pkg_needed: no mgr → 0" "0" "$_SHDEPS_PKG_INSTALL_NEEDED"

# --- _shdeps_check_pkg_needed: idempotent (does not re-scan) ---

_SHDEPS_PKG_MGR="dnf"
_SHDEPS_PKG_INSTALL_NEEDED=0
_shdeps_check_pkg_needed
_assert_eq "check_pkg_needed: idempotent (cached 0)" "0" "$_SHDEPS_PKG_INSTALL_NEEDED"
_SHDEPS_PKG_INSTALL_NEEDED=1
_shdeps_check_pkg_needed
_assert_eq "check_pkg_needed: idempotent (cached 1)" "1" "$_SHDEPS_PKG_INSTALL_NEEDED"

# --- _shdeps_pkg_refresh_metadata: skips when no install needed ---

unset _SHDEPS_PKG_INSTALL_NEEDED _SHDEPS_PKG_CACHE_REFRESHED
_SHDEPS_PKG_MGR="dnf"
# All deps installed (tool-a exists from earlier mock)
cat >"$_cpn_dir/deps.conf" <<'EOF'
tool-a  pkg
EOF
_saved_path="$PATH"
export PATH="$_cpn_bin:$PATH"
SHDEPS_CONF_DIR="$_cpn_dir" _shdeps_load
unset _SHDEPS_PKG_INSTALL_NEEDED
_shdeps_pkg_refresh_metadata
_assert_neq "refresh_metadata: skipped when all installed" "1" "${_SHDEPS_PKG_CACHE_REFRESHED:-}"
export PATH="$_saved_path"

# --- _shdeps_pkg_refresh_metadata: idempotent via _SHDEPS_PKG_CACHE_REFRESHED ---

_SHDEPS_PKG_INSTALL_NEEDED=1
_SHDEPS_PKG_CACHE_REFRESHED=1
_shdeps_pkg_refresh_metadata
_assert_eq "refresh_metadata: idempotent" "1" "$_SHDEPS_PKG_CACHE_REFRESHED"

# Restore state
unset _SHDEPS_PKG_INSTALL_NEEDED _SHDEPS_PKG_CACHE_REFRESHED
_source_shdeps "$SHDEPS_DIR"

# ===========================================================================
# Section 5: Binary asset matching
# ===========================================================================

echo ""
echo "=== Binary asset matching ==="

# Platform detection for test assertions
_test_os=$(uname -s | tr '[:upper:]' '[:lower:]')
_test_arch=$(uname -m)
case "$_test_arch" in
  x86_64)  _test_arch_alt=amd64 ;;
  aarch64) _test_arch_alt=arm64 ;;
  arm64)   _test_arch_alt=aarch64 ;;
  *)       _test_arch_alt="$_test_arch" ;;
esac
_test_OS="$(uname -s)"

# --- Rust triple: tar.gz with OS and arch ---

_json=$(_fake_release_json \
  "tool-x86_64-unknown-linux-gnu.tar.gz" \
  "tool-aarch64-unknown-linux-gnu.tar.gz" \
  "tool-x86_64-apple-darwin.tar.gz" \
  "tool-aarch64-apple-darwin.tar.gz")
result=$(_shdeps_binary_find_asset "tool" "test/tool" "v1.0.0" "$_json")
_assert_contains "rust triple: matches platform" "${_test_os}" "$result"
if [[ "$result" == *"${_test_arch}"* || "$result" == *"${_test_arch_alt}"* ]]; then
  _pass "rust triple: matches arch"
else
