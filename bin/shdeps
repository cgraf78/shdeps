#!/usr/bin/env bash
# shdeps — CLI wrapper for the shdeps shell dependency manager.
#
# Finds and sources shdeps.sh relative to its own location, then dispatches
# to the requested subcommand.

set -euo pipefail

# Resolve symlinks to find the real script location
_shdeps_cli_realpath() {
  local path="$1"
  while [[ -L "$path" ]]; do
    local dir
    dir=$(cd -P "$(dirname "$path")" && pwd)
    path=$(readlink "$path")
    [[ "$path" != /* ]] && path="$dir/$path"
  done
  cd -P "$(dirname "$path")" && pwd
}

SHDEPS_CLI_DIR=$(_shdeps_cli_realpath "${BASH_SOURCE[0]}")
SHDEPS_LIB="$SHDEPS_CLI_DIR/../shdeps.sh"

if [[ ! -f "$SHDEPS_LIB" ]]; then
  echo "error: cannot find shdeps.sh at $SHDEPS_LIB" >&2
  exit 1
fi

# ---------------------------------------------------------------------------
# Usage
# ---------------------------------------------------------------------------

usage() {
  cat <<'EOF'
Usage: shdeps [options] <command> [args]

Commands:
  update          Install/update all dependencies
  self-update     Update shdeps itself (git pull, skips dirty trees)
  list            List all configured dependencies with status
  check <name>    Check if a specific dependency is installed
  prune           Remove orphaned deps no longer in config
  version         Print shdeps version
  help            Show this help message

Options:
  -c, --config <path>   Config directory or file (default: ~/.config/shdeps/)
  -f, --force           Bypass TTL cache (check for updates now)
  -R, --reinstall       Force reinstall all dependencies (implies --force)
  -q, --quiet           Suppress interactive prompts
  -v, --verbose         Verbose output (log level 2)

Prune options:
  -y                    Skip confirmation prompt
  --dry-run             Show what would be removed without removing

Examples:
  shdeps update
  shdeps -c ~/.config/myapp/ update
  shdeps --force update
  shdeps list
  shdeps check jq
  shdeps prune --dry-run
  shdeps prune -y

Exit codes:
  0  Success
  1  Error
  2  Usage error
EOF
}

# ---------------------------------------------------------------------------
# Subcommands
# ---------------------------------------------------------------------------

cmd_update() {
  shdeps_update
}

# Delegate to the library's self-update implementation.
cmd_self_update() {
  shdeps_self_update "$SHDEPS_CLI_DIR/.."
}

# shellcheck disable=SC2154  # _name, _method, _cmd, _aliases, _filter set by _shdeps_parse
cmd_list() {
  _shdeps_load
  _shdeps_pkg_detect
  _shdeps_manifest_read

  # shellcheck disable=SC2154  # _SHDEPS_DEPS set by _shdeps_load
  if [[ ${#_SHDEPS_DEPS[@]} -eq 0 ]]; then
    echo "No dependencies configured."
    return 0
  fi

  # Pre-pass: find longest name and method to size columns dynamically.
  local _ncol=4 _mcol=6  # minimums: "NAME", "METHOD"
  local _e _n _m
  for _e in "${_SHDEPS_DEPS[@]}"; do
    _n="${_e%%|*}"
    _m="${_e#*|}"; _m="${_m%%|*}"
    (( ${#_n} > _ncol )) && _ncol=${#_n}
    (( ${#_m} > _mcol )) && _mcol=${#_m}
  done

  printf "%-${_ncol}s %-${_mcol}s %-12s %s\n" "NAME" "METHOD" "STATUS" "DETAILS"
  printf "%-${_ncol}s %-${_mcol}s %-12s %s\n" "----" "------" "------" "-------"

  local entry
  for entry in "${_SHDEPS_DEPS[@]}"; do
    _shdeps_parse "$entry"

    # shellcheck disable=SC2154  # _name, _method, _cmd, _aliases, _filter set by _shdeps_parse
    local _frc=0
    _shdeps_filter_match "$_filter" || _frc=$?
    if [[ $_frc -eq 1 ]]; then
      printf "%-${_ncol}s %-${_mcol}s %-12s %s\n" "$_name" "$_method" "skipped" "(platform)"
      continue
    elif [[ $_frc -eq 2 ]]; then
      printf "%-${_ncol}s %-${_mcol}s %-12s %s\n" "$_name" "$_method" "skipped" "(host)"
      continue
    fi

    local status="missing" details=""
    case "$_method" in
    pkg)
      local resolved
      resolved=$(_shdeps_resolve_override "$_name" "$_aliases")
      if [[ "$resolved" == "NONE" ]]; then
        status="skipped"
        details="(pkg manager)"
      elif _shdeps_exists "$_cmd" "$resolved"; then
        status="installed"
        local ver
        ver=$(_shdeps_dep_version "$_cmd" 2>/dev/null || true)
        [[ -n "$ver" ]] && details="$ver"
      fi
      ;;
    github:repo)
      if [[ -d "$(_shdeps_install_dir)/$_name" ]]; then
        status="installed"
        local ver
        ver=$(_shdeps_get_version "$(_shdeps_install_dir)/$_name")
        [[ -n "$ver" ]] && details="$ver"
      fi
      ;;
    github:release|cargo|go)
      # Binary path lives in the manifest's fourth column. Empty manifest
      # entry → "missing" (install hasn't run yet).
      local bin_path=""
      if [[ -n "${_SHDEPS_MANIFEST[$_name]+x}" ]]; then
        bin_path="${_SHDEPS_MANIFEST[$_name]##*|}"
      fi
      if [[ -n "$bin_path" && -x "$bin_path" ]]; then
        status="installed"
        local ver
        ver=$(_shdeps_dep_version "$_cmd" 2>/dev/null || true)
        [[ -n "$ver" ]] && details="$ver"
      fi
      ;;
    custom)
      local hooks_dir hook_file
      hooks_dir=$(_shdeps_hooks_dir)
      hook_file="$hooks_dir/$_name.sh"
      if [[ -f "$hook_file" ]]; then
        unset -f exists version install post uninstall 2>/dev/null
        # shellcheck source=/dev/null
        . "$hook_file" 2>/dev/null
        if declare -f exists &>/dev/null && exists "$_name"; then
          status="installed"
          if declare -f version &>/dev/null; then
            local ver
            ver=$(version "$_name" 2>/dev/null) || ver=""
            [[ -n "$ver" ]] && details="$ver"
          fi
        fi
        unset -f exists version install post uninstall 2>/dev/null
      fi
      ;;
    esac

    printf "%-${_ncol}s %-${_mcol}s %-12s %s\n" "$_name" "$_method" "$status" "$details"
  done
}

# shellcheck disable=SC2154  # _name, _method, _cmd, _aliases, _filter set by _shdeps_parse
cmd_check() {
  local target="${1:-}"
  if [[ -z "$target" ]]; then
    echo "error: check requires a dependency name" >&2
    echo "Usage: shdeps check <name>" >&2
    return 2
  fi

  _shdeps_load
  _shdeps_pkg_detect
  _shdeps_manifest_read

  local entry found=0
  for entry in "${_SHDEPS_DEPS[@]}"; do
    _shdeps_parse "$entry"
    # shellcheck disable=SC2154  # _name, _method, _cmd, _aliases, _filter set by _shdeps_parse
    [[ "$_name" == "$target" ]] || continue
    found=1

    local _frc=0
    _shdeps_filter_match "$_filter" || _frc=$?
    if [[ $_frc -eq 1 ]]; then
      echo "$_name: skipped (platform mismatch)"
      return 0
    elif [[ $_frc -eq 2 ]]; then
      echo "$_name: skipped (host mismatch)"
      return 0
    fi

    case "$_method" in
    pkg)
      local resolved
      resolved=$(_shdeps_resolve_override "$_name" "$_aliases")
      if [[ "$resolved" == "NONE" ]]; then
        echo "$_name: skipped (pkg manager)"
        return 0
      elif _shdeps_exists "$_cmd" "$resolved"; then
        local ver
        ver=$(_shdeps_dep_version "$_cmd" 2>/dev/null || true)
        echo "$_name: installed${ver:+ ($ver)}"
        return 0
      fi
      ;;
    github:repo)
      if [[ -d "$(_shdeps_install_dir)/$_name" ]]; then
        local ver
        ver=$(_shdeps_get_version "$(_shdeps_install_dir)/$_name")
        echo "$_name: installed${ver:+ ($ver)}"
        return 0
      fi
      ;;
    github:release|cargo|go)
      local bin_path=""
      if [[ -n "${_SHDEPS_MANIFEST[$_name]+x}" ]]; then
        bin_path="${_SHDEPS_MANIFEST[$_name]##*|}"
      fi
      if [[ -n "$bin_path" && -x "$bin_path" ]]; then
        local ver
        ver=$(_shdeps_dep_version "$_cmd" 2>/dev/null || true)
        echo "$_name: installed${ver:+ ($ver)}"
        return 0
      fi
      ;;
    custom)
      local hooks_dir hook_file
      hooks_dir=$(_shdeps_hooks_dir)
      hook_file="$hooks_dir/$_name.sh"
      if [[ -f "$hook_file" ]]; then
        unset -f exists version install post uninstall 2>/dev/null
        # shellcheck source=/dev/null
        . "$hook_file" 2>/dev/null
        if declare -f exists &>/dev/null && exists "$_name"; then
          local ver=""
          if declare -f version &>/dev/null; then
            ver=$(version "$_name" 2>/dev/null) || ver=""
          fi
          echo "$_name: installed${ver:+ ($ver)}"
          unset -f exists version install post uninstall 2>/dev/null
          return 0
        fi
        unset -f exists version install post uninstall 2>/dev/null
      fi
      ;;
    esac

    echo "$_name: not installed"
    return 1
  done

  if [[ $found -eq 0 ]]; then
    echo "error: unknown dependency '$target'" >&2
    return 1
  fi
}

cmd_prune() {
  shdeps_prune "$@"
}

# ---------------------------------------------------------------------------
# Migrate — one-off command to move state from bare-name to owner/repo paths.
# Delete this function and its case branch after migration is complete.
# ---------------------------------------------------------------------------

cmd_migrate() {
  local dry_run=0
  [[ "${1:-}" == "--dry-run" ]] && dry_run=1

  _shdeps_load
  _shdeps_pkg_detect

  local install_dir state_dir manifest
  install_dir=$(_shdeps_install_dir)
  state_dir=$(_shdeps_state_dir)
  manifest=$(_shdeps_manifest_path)

  local count=0
  echo "==> Scanning for github deps needing migration..."

  local entry
  for entry in "${_SHDEPS_DEPS[@]}"; do
    _shdeps_parse "$entry"
    [[ "$_method" == github:repo || "$_method" == github:release ]] || continue
    [[ "$_name" == */* ]] || continue

    local short old_install new_install
    short=$(_shdeps_short_name "$_name")
    old_install="$install_dir/$short"
    new_install="$install_dir/$_name"

    # Skip if nothing to clean up
    if [[ ! -e "$old_install" && ! -L "$old_install" ]]; then continue; fi

    # When owner == repo (e.g., neovim/neovim), old_install is the parent
    # of new_install — it's structural, not stale. Skip.
    if [[ "$new_install" == "$old_install"/* ]]; then continue; fi

    # New path already exists (shdeps update already ran) — just remove old
    if [[ -e "$new_install" || -L "$new_install" ]]; then
      echo "  $short (removing stale old path)"
      count=$((count + 1))
      if [[ $dry_run -eq 1 ]]; then
        echo "    remove: $old_install"
        continue
      fi
      rm -rf "$old_install"
      # Clean up old state files too
      rm -f "$state_dir/$short".*.stamp "$state_dir/$short.rev" "$state_dir/$short.links"
      # Remove old manifest entry (github methods incl. pre-rename git/binary)
      if [[ -f "$manifest" ]]; then
        local tmp="$manifest.tmp.$$"
        awk -F'|' -v old="$short" \
          '$1 != old || ($2 != "github:repo" && $2 != "github:release" && $2 != "git" && $2 != "binary")' \
          "$manifest" > "$tmp"
        mv "$tmp" "$manifest"
      fi
      continue
    fi

    echo "  $short → $_name"
    count=$((count + 1))

    if [[ $dry_run -eq 1 ]]; then
      echo "    install: $old_install → $new_install"
      continue
    fi

    # Move install dir (handle symlinks for local dev clones)
    mkdir -p "$(dirname "$new_install")"
    if [[ -L "$old_install" ]]; then
      ln -sfn "$(readlink "$old_install")" "$new_install"
      rm -f "$old_install"
    else
      mv "$old_install" "$new_install"
    fi

    # Move state files
    local f suffix
    for f in "$state_dir/$short".*.stamp "$state_dir/$short.rev" "$state_dir/$short.links"; do
      [[ -f "$f" ]] || continue
      suffix="${f#"$state_dir/$short"}"
      mkdir -p "$state_dir/$(dirname "$_name")"
      mv "$f" "$state_dir/$_name$suffix"
    done

    # Update manifest (match name AND github method to avoid renaming pkg deps)
    if [[ -f "$manifest" ]]; then
      local tmp="$manifest.tmp.$$"
      awk -F'|' -v old="$short" -v new="$_name" -v olddir="$install_dir/$short" -v newdir="$install_dir/$_name" \
        'BEGIN{OFS="|"} $1==old && ($2=="github:repo" || $2=="github:release" || $2=="git" || $2=="binary"){$1=new; gsub(olddir,newdir)} {print}' \
        "$manifest" > "$tmp"
      mv "$tmp" "$manifest"
    fi
  done

  # Sweep manifest: remove any bare-name github/git/binary entry whose name
  # doesn't match a current config dep. Catches cases where the old manifest
  # name differs from the repo short name (e.g., shfmt vs mvdan/sh).
  if [[ $dry_run -eq 0 && -f "$manifest" ]]; then
    local -A config_names=()
    for entry in "${_SHDEPS_DEPS[@]}"; do
      config_names["${entry%%|*}"]=1
    done
    local swept=0 m_name m_rest
    while IFS='|' read -r m_name m_rest || [[ -n "$m_name" ]]; do
      [[ -n "$m_name" ]] || continue
      local m_method="${m_rest%%|*}"
      # Only target github/git/binary entries with bare names (no slash)
      [[ "$m_name" != */* ]] || continue
      case "$m_method" in
        github:repo|github:release|git|binary) ;;
        *) continue ;;
      esac
      # If this bare name isn't in the current config, it's stale
      [[ -z "${config_names[$m_name]+x}" ]] || continue
      swept=$((swept + 1))
    done < "$manifest"
    if [[ $swept -gt 0 ]]; then
      local tmp="$manifest.tmp.$$"
      awk -F'|' '$1 ~ /\// || ($2 != "github:repo" && $2 != "github:release" && $2 != "git" && $2 != "binary")' \
        "$manifest" > "$tmp"
      mv "$tmp" "$manifest"
      echo "  cleaned $swept stale manifest entry/entries"
      count=$((count + swept))
    fi
  fi

  # Clean up old dotfiles state dir (dot used to override SHDEPS_STATE_DIR)
  local old_dot_state="${XDG_STATE_HOME:-$HOME/.local/state}/dot/deps"
  if [[ -d "$old_dot_state" ]]; then
    if [[ $dry_run -eq 1 ]]; then
      echo "  would remove old dotfiles state dir: $old_dot_state"
    else
      rm -rf "$old_dot_state"
      echo "  removed old dotfiles state dir"
    fi
    count=$((count + 1))
  fi

  if [[ $dry_run -eq 1 && $count -gt 0 ]]; then
    echo ""
    echo "Dry run: $count dep(s) would be migrated. Re-run without --dry-run to apply."
  elif [[ $count -gt 0 ]]; then
    echo ""
    echo "==> Migrated $count dep(s). Run 'shdeps list' to verify."
  else
    echo "  Nothing to migrate — all deps already at owner/repo paths."
  fi
}

# ---------------------------------------------------------------------------
# Argument parsing
# ---------------------------------------------------------------------------

main() {
  local config_path=""

  while [[ $# -gt 0 ]]; do
    case "$1" in
    -c|--config)
      [[ $# -lt 2 ]] && { echo "error: --config requires an argument" >&2; exit 2; }
      config_path="$2"
      shift 2
      ;;
    -f|--force)
      export SHDEPS_FORCE=1
      shift
      ;;
    -R|--reinstall)
      export SHDEPS_FORCE=1
      export SHDEPS_REINSTALL=1
      shift
      ;;
    -q|--quiet)
      export SHDEPS_QUIET=1
      shift
      ;;
    -v|--verbose)
      export SHDEPS_LOG_LEVEL=2
      shift
      ;;
    -h|--help|help)
      usage
      exit 0
      ;;
    -*)
      echo "error: unknown option '$1'" >&2
      echo "Run 'shdeps help' for usage." >&2
      exit 2
      ;;
    *)
      break
      ;;
    esac
  done

  # Apply config dir before sourcing the library.
  # -c flag accepts a directory or a file (dirname is used).
  # Priority: -c flag > SHDEPS_CONF_DIR env > XDG default
  if [[ -n "$config_path" ]]; then
    if [[ -d "$config_path" ]]; then
      SHDEPS_CONF_DIR="$config_path"
    else
      SHDEPS_CONF_DIR="$(dirname "$config_path")"
    fi
    export SHDEPS_CONF_DIR
  elif [[ -z "${SHDEPS_CONF_DIR:-}" ]]; then
    export SHDEPS_CONF_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/shdeps"
  fi

  # Source the library
  # shellcheck disable=SC1091  # path resolved at runtime
  # shellcheck source=../shdeps.sh
  source "$SHDEPS_LIB"

  local cmd="${1:-help}"
  shift || true

  case "$cmd" in
  update)      cmd_update "$@" ;;
  self-update) cmd_self_update "$@" ;;
  list)        cmd_list "$@" ;;
  check)       cmd_check "$@" ;;
  prune)       cmd_prune "$@" ;;
  migrate)     cmd_migrate "$@" ;;
  version)     shdeps_version ;;
  help)        usage ;;
  *)
    echo "error: unknown command '$cmd'" >&2
    echo "Run 'shdeps help' for usage." >&2
    exit 2
    ;;
  esac
}

main "$@"
